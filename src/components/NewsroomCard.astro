---
import type { NewsroomCardItem, Newsletter, Toolkit } from "@/src/types";

type NewsroomCardInput = NewsroomCardItem | Toolkit | Newsletter;

interface Props {
  item: NewsroomCardInput;
  class?: string;
  showPills?: boolean;
  showSubtitle?: boolean;
  pillSource?: "topics" | "content_types";
  showColoredLabel?: boolean;
  btnClass?: string;
  showImage?: boolean;
  ctaText?: string;
}

const {
  item,
  class: className = "",
  showPills = true,
  showSubtitle,
  pillSource = "topics",
  showColoredLabel = true,
  showImage = false,
  btnClass = 'btn w-100 mt-2',
  ctaText = "View Toolkit",
} = Astro.props;

// Normalize related content types into one render-safe shape.
const normalizeItem = (value: NewsroomCardInput): NewsroomCardItem => {
  const newsletterValue = value as Newsletter;

  return {
    title: value.title,
    url: value.url,
    description: value.description,
    content_types: value.content_types,
    topics: value.topics,
    issue: newsletterValue.issue,
    date: value.date,
    subtitle: value.subtitle,
    imageUrl: newsletterValue.imageUrl,
  };
};

const normalizedItem = normalizeItem(item);

// Build predictable data-topic values used by CSS selectors.
const slugifyForId = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

  // Prefer topic labels, then subtitle as a fallback for pill text/color mapping.
const labelText = normalizedItem.topics?.join(", ") ?? normalizedItem.subtitle ?? "";
const labelKey = normalizedItem.topics?.[0] ?? normalizedItem.subtitle ?? "";
const topicSlug = labelKey ? slugifyForId(labelKey) : "";

  // If no description exists, use date as lightweight metadata text.
const descriptionText = normalizedItem.description ?? "";
const fallbackText = !normalizedItem.description && normalizedItem.date ? normalizedItem.date : "";

  // Image display is opt-in and only renders when a source URL exists.
const shouldRenderImage = Boolean(showImage && normalizedItem.imageUrl);
const imageAltText = normalizedItem.title?.trim() || "Newsletter image";

  // External links open in a new tab with safe rel attributes.
const isExternalUrl = Boolean(normalizedItem.url && /^https?:\/\//i.test(normalizedItem.url));
const shouldShowSubtitle = Boolean(normalizedItem.subtitle && (showSubtitle ?? !showPills));
const pillItems =
  pillSource === "content_types"
    ? (normalizedItem.content_types?.length ? normalizedItem.content_types : normalizedItem.topics)
    : normalizedItem.topics;
const shouldShowBadges = Boolean(showPills && pillItems?.length);
---

<div class:list={["card toolkit-card", className]}>
  {
    showColoredLabel && (
      <h3 class="colored-label" data-topic={topicSlug}>
        {labelText}
      </h3>
    )
  }

  <div class="card-body">
  <div class="">
    {shouldShowSubtitle && <p class="card-subtitle mb-2">{normalizedItem.subtitle}</p>}
    {
      // Switch between a visual title image and text title depending on props/content.
      shouldRenderImage ? (
        <>
          <div class="card-title-image-wrap" aria-label={imageAltText}>
            <img class="card-title-image" src={normalizedItem.imageUrl} alt={imageAltText} loading="lazy" decoding="async" />
          </div>
          <h5>{normalizedItem.title}</h5>
        </>
      ) : (
        <h5 class="card-title">{normalizedItem.title}</h5>
      )
    }

    {/* Render description when available, otherwise show fallback date text. */}
    {(descriptionText || fallbackText) && <p class="card-text">{descriptionText || fallbackText}</p>}

    {
      shouldShowBadges && (
        <div class="d-flex flex-wrap badge-container">
          {
            pillItems?.map((ct) => (
              <p class="badge me-1">{ct}</p>
            ))
          }
        </div>
      )
    }
    </div>
    {normalizedItem.url && (
      <a href={normalizedItem.url} class={btnClass} target={isExternalUrl ? "_blank" : undefined} rel={isExternalUrl ? "noopener noreferrer" : undefined}>
        {ctaText}
      </a>
    )}
  </div>
</div>

<style>

.newsletter-link {
  text-decoration: none;
}
.toolkit-card.media-toolkit {
  min-height: 280px; 

}
.badge-container { 
  min-height: 75px;
  align-items: flex-start;
  align-content: flex-start;
}
  .toolkit-card.newsletter-card {
    padding: 0;
    flex-direction: row;
  }
  .featured-newsletter-card .card-title {
    height: 200px;
    flex-direction: column; 
    color: white;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
    background: linear-gradient(90deg, #1C2C4E, #1E4D86);
  }

  .newsletter-card .card-title-image-wrap {
    height: auto;
    border-radius: 0;
    overflow: hidden;
    background: transparent;
  }

  .featured-newsletter-card .card-title-image-wrap {
    background: linear-gradient(90deg, #1C2C4E, #1E4D86);
  }

  .card-title-image {
    width: 100%;
    object-fit: cover;
    display: block;
  }
  

  .card-subtitle {
    color: rgb(var(--bs-primary-rgb));
    font-size: 1rem;
    font-weight: 600;
  }


  .badge {
    background-color: #E8F1F9;
    color: #1F5493;
    text-transform: capitalize;
  }
  .toolkit-card {
    padding: 1rem;
    display: flex; 
    flex-direction: column;
    justify-content: space-between;
  }

  

  .colored-label {
    display: inline-block;
    width: fit-content;
    margin: 0 0 0.75rem 0;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    background-color: rgba(var(--bs-secondary-rgb), 0.18);
    color: rgb(var(--bs-secondary-rgb));
  }

  .colored-label[data-topic="v2x"] {
    background-color: rgba(var(--bs-primary-rgb), 0.18);
    color: rgb(var(--bs-primary-rgb));
  }

  .colored-label[data-topic="ai"] {
    background-color: rgba(var(--bs-info-rgb), 0.18);
    color: rgb(var(--bs-info-rgb));
  }

  .colored-label[data-topic="intersection-safety"] {
    background-color: rgba(var(--bs-danger-rgb), 0.18);
    color: rgb(var(--bs-danger-rgb));
  }

  .colored-label[data-topic="automation"] {
    background-color: rgba(var(--bs-success-rgb), 0.18);
    color: rgb(var(--bs-success-rgb));
  }

  .colored-label[data-topic="its4us"] {
    background-color: rgba(var(--bs-warning-rgb), 0.18);
    color: rgb(var(--bs-warning-rgb));
  }

  .colored-label[data-topic="freight"] {
    background-color: rgba(var(--bs-dark-rgb), 0.12);
    color: rgb(var(--bs-dark-rgb));
  }
</style>