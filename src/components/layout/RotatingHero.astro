<script>
  const carousel = document.querySelector(".hero-carousel .slides") as HTMLElement;
  const contentBoxes = document.querySelectorAll(".content-box");
  const slideWidth = carousel?.offsetWidth || 0;
  const totalSlides = 4;
  let currentSlide = 0;
  let autoRotateInterval: ReturnType<typeof setInterval>;

  function updateActiveSlide() {
    if (!carousel) return;
    const newSlide = Math.round(carousel.scrollLeft / carousel.offsetWidth);

    if (newSlide !== currentSlide) {
      // Remove active class from all
      contentBoxes.forEach((box) => box.classList.remove("active"));

      // Add active class to current slide's content
      if (contentBoxes[newSlide]) {
        contentBoxes[newSlide].classList.add("active");
      }

      currentSlide = newSlide;
    }
  }

  function rotateToNextSlide() {
    if (!carousel) return;
    currentSlide = (currentSlide + 1) % totalSlides;
    carousel.scrollTo({
      left: currentSlide * carousel.offsetWidth,
      behavior: "smooth",
    });
  }

  function startAutoRotate() {
    autoRotateInterval = setInterval(rotateToNextSlide, 10000);
  }

  function stopAutoRotate() {
    if (autoRotateInterval) {
      clearInterval(autoRotateInterval);
    }
  }

  // Initialize first slide as active
  if (contentBoxes[0]) {
    contentBoxes[0].classList.add("active");
  }

  // Start auto-rotation
  startAutoRotate();

  // Pause on hover
  carousel?.addEventListener("mouseenter", stopAutoRotate);
  carousel?.addEventListener("mouseleave", startAutoRotate);

  // Update active slide on scroll
  carousel?.addEventListener("scroll", updateActiveSlide);
</script>

<style>
  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: white;
    text-wrap: balance;
  }
  section {
    margin: 0;
    padding: 0;
  }
  .hero-carousel {
    position: relative;
    min-height: 500px;
    isolation: isolate;
  }

  /* Scroll container with snap */
  .slides {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    height: 100%;
    scroll-marker-group: after;
  }

  .slides::-webkit-scrollbar {
    display: none;
  }

  /* Individual slides */
  .slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    min-height: 500px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
  }

  /* Scroll marker group positioning */
  .slides::scroll-marker-group {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.75rem;
    z-index: 10;
  }

  /* Individual scroll markers */
  .slide::scroll-marker {
    content: "";
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    outline: rgba(0, 0, 0, 0.5) solid 1px;
    cursor: pointer;
    transition: all 0.3s ease-in-out;
  }

  .slide::scroll-marker:hover {
    background: rgba(255, 255, 255, 0.8);
    transform: scale(1.2);
  }

  .slide::scroll-marker:focus,
  .slide::scroll-marker:target-current {
    outline: 2px solid white;
    outline-offset: 3px;
    background-color: #efbd27;
  }

  /* Scroll buttons */
  .slides::scroll-button(left),
  .slides::scroll-button(right) {
    content: "\f053";
    font-family: FontAwesome;
    font-size: 16px;
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(calc(-50% - 80px));
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    background-color: #efbd27;
    color: black;
    font-weight: 800;
    border-color: transparent;
  }

  .slides::scroll-button(right) {
    content: "\f054";
    left: 50%;
    transform: translateX(calc(-50% + 80px));
  }

  .slides::scroll-button(left):hover,
  .slides::scroll-button(right):hover {
    background-color: #66a3cc;
    color: white;
    border-color: transparent;
  }

  .slides::scroll-button(left):focus,
  .slides::scroll-button(right):focus {
    box-shadow: 0 0 0 0.2rem rgba(255, 255, 255, 0.25);
  }

  .slides::scroll-button(left):disabled,
  .slides::scroll-button(right):disabled {
    background-color: rgba(255, 255, 255, 0.5);
    color: rgba(0, 0, 0, 0.5);
    cursor: not-allowed;
    border-color: transparent;
  }

  /* Content box */
  .content-box {
    background: rgba(7, 46, 85, 0.85);
    border-radius: 15px;
    padding: 2rem;
    max-width: 720px;
    color: white;
    margin: 1rem 0 5rem 0;
    opacity: 0;
    transform: translateX(100px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
  }

  .content-box.active {
    opacity: 1;
    transform: translateX(0);
  }

  .content-box h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .content-box h2.newsLetterHeader {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #efbd27;
  }

  .content-box p {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    line-height: 1.6;
    text-wrap: pretty;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .hero-carousel {
      min-height: 400px;
    }

    .slide {
      min-height: 400px;
    }

    .content-box {
      padding: 1.25rem;
      margin: 1rem 0 5rem 0;
    }

    .content-box h2 {
      font-size: 1.5rem;
    }

    .content-box p {
      font-size: 1rem;
    }
  }

  .icon-arrow-button::after {  
    content: "\f061";
    font-family: FontAwesome;
    margin-left: 0.5rem;
    display: inline-block;
    }

    .icon-external-link::after {
      content: "\f35d";
      font-family: FontAwesome;
    margin-left: 0.5rem;
    
    display: inline-block;
    }

    .icon-external-link:hover::after, .icon-arrow-button:hover::after {
      transform: translateX(5px);
      transition: transform 0.3s ease-in-out;
    }
</style>
