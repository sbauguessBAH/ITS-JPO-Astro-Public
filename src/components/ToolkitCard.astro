---
type Toolkit = {
  content_types?: string[];
  topics?: string[];
  title?: string;
  url?: string;
  description?: string;
  last_updated?: string;
  toolkit_type?: string;
};

interface Props {
  toolkit: Toolkit;
  showPills?: boolean;
  showColoredLabel?: boolean;
  ctaText?: string;
}

const {
  toolkit,
  showPills = true,
  showColoredLabel = true,
  ctaText = "View Toolkit",
} = Astro.props;

const slugifyForId = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");

const topicSlug = toolkit.topics?.[0] ? slugifyForId(toolkit.topics[0]) : "";
const descriptionText = toolkit.description ?? "";
const fallbackText = !toolkit.description && toolkit.last_updated ? toolkit.last_updated : "";
---

<div class="card h-100 toolkit-card">
  {
    showColoredLabel && (
      <h3 class="colored-label" data-topic={topicSlug}>
        {toolkit.topics?.join(", ")}
      </h3>
    )
  }

  <div class="card-body">
    <h5 class="card-title">{toolkit.title}</h5>

    {(descriptionText || fallbackText) && <p class="card-text">{descriptionText || fallbackText}</p>}

    {
      showPills &&
        toolkit.content_types?.map((ct) => (
          <p class="badge bg-secondary me-1">{ct}</p>
        ))
    }

    {toolkit.url && (
      <a href={toolkit.url} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
        {ctaText}
      </a>
    )}
  </div>
</div>

<style>
  .toolkit-card {
    padding: 1rem;
  }

  .toolkit-card > .card-body {
    padding: 0;
  }

  .colored-label {
    display: inline-block;
    width: fit-content;
    margin: 0 0 0.75rem 0;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    background-color: rgba(var(--bs-secondary-rgb), 0.18);
    color: rgb(var(--bs-secondary-rgb));
  }

  .colored-label[data-topic="v2x"] {
    background-color: rgba(var(--bs-primary-rgb), 0.18);
    color: rgb(var(--bs-primary-rgb));
  }

  .colored-label[data-topic="ai"] {
    background-color: rgba(var(--bs-info-rgb), 0.18);
    color: rgb(var(--bs-info-rgb));
  }

  .colored-label[data-topic="intersection-safety"] {
    background-color: rgba(var(--bs-danger-rgb), 0.18);
    color: rgb(var(--bs-danger-rgb));
  }

  .colored-label[data-topic="automation"] {
    background-color: rgba(var(--bs-success-rgb), 0.18);
    color: rgb(var(--bs-success-rgb));
  }

  .colored-label[data-topic="its4us"] {
    background-color: rgba(var(--bs-warning-rgb), 0.18);
    color: rgb(var(--bs-warning-rgb));
  }

  .colored-label[data-topic="freight"] {
    background-color: rgba(var(--bs-dark-rgb), 0.12);
    color: rgb(var(--bs-dark-rgb));
  }
</style>
