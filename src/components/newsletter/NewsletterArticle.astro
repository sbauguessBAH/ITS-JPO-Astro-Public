---
interface Props {
  title: string;
  imageUrl?: string;
  imageAlt?: string;
  imageSource?: string;
}

const { title, imageUrl, imageAlt, imageSource } = Astro.props;
---

<article class="newsletter-article">
  {imageUrl && (
    <figure class="newsletter-image">
      <img src={imageUrl} alt={imageAlt || title} />
      {imageSource && (
        <figcaption>Source: {imageSource}</figcaption>
      )}
    </figure>
  )}
  
  <h2 class="newsletter-article-title">{title}</h2>
  
  <div class="newsletter-article-content">
    <slot />
  </div>
</article>

<style>
  .newsletter-article {
    margin: 1.5rem 0;
  }

  .newsletter-image {
    margin: 0 0 1rem 0;
  }

  .newsletter-image img {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
  }

  .newsletter-image figcaption {
    font-size: 0.75rem;
    color: #666;
    text-align: right;
    margin-top: 0.75rem;
    font-family: "Tahoma", sans-serif;
  }

  .newsletter-article-title {
    font-size: 1.15rem;
    color: #1e3769;
    font-family: "Tahoma", sans-serif;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .newsletter-article-content {
    font-size: 0.85rem;
    font-family: "Tahoma", sans-serif;
    line-height: 1.6;
    color: #333;
  }

  .newsletter-article-content :global(p) {
    margin-bottom: 1rem;
  }

  .newsletter-article-content :global(a) {
    color: #167796;
    text-decoration: underline;
  }

  .newsletter-article-content :global(ul) {
    margin: 0.5rem 0;
    padding-left: 2rem;
  }

  .newsletter-article-content :global(li) {
    margin-bottom: 0.25rem;
  }
</style>
