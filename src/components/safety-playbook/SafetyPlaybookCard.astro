---
import type { CollectionEntry } from 'astro:content';
import base_url from '@/src/lib/base_url';

interface Props {
  item: CollectionEntry<'safetyPlaybook'>;
}

const { item } = Astro.props;
const data = item.data;

const entryPath = item.id.replace(/\.(md|mdx)$/i, "");
const slugPath = base_url(`/research-areas/safety-playbook/${entryPath}/`);

const normalize = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/\s+/g, '-');

const toDataValue = (values: string[]) => values.map(normalize).join('|');
const toSearchDataValue = (values: string[]) => values.join('|');

interface ContextTag {
  label: string;
  type: 'safety' | 'location' | 'facility';
}

const uniqueValues = (values: string[]) => [...new Set(values.map((value) => value.trim()).filter(Boolean))];

const safetyTags = uniqueValues(data.safety);
const areaTypeTags = uniqueValues(data.location);
const facilityTags = uniqueValues(data.facility);

const contextTags: ContextTag[] = [
  ...safetyTags.map((label) => ({ label, type: 'safety' as const })),
  ...areaTypeTags.map((label) => ({ label, type: 'location' as const })),
  ...facilityTags.map((label) => ({ label, type: 'facility' as const })),
];

