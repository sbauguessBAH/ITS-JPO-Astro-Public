---
import { Image } from "astro:assets";
import baa from "@/src/assets/images/its4us/BAA.png";
import gmap from "@/src/assets/images/its4us/GMAP.png";
import hc from "@/src/assets/images/its4us/HC.png";
import tdei from "@/src/assets/images/its4us/TDEI.png";
import baaIcon from "@/src/assets/images/its4us/buffalo-icon.png";
import gmapIcon from "@/src/assets/images/its4us/Georgia-icon.png"; 
import hcIcon from "@/src/assets/images/its4us/Health-Connector-icon.png";
import tdeiIcon from "@/src/assets/images/its4us/TDEI-icon.png";


interface Props {
	title: string;
	alt: string;
    img: string;
    color: string;
	href: string;
    logo: string;
    logo_alt: string;
}

const { href, title, alt, img, color, logo, logo_alt } = Astro.props;

const imageByKey = {
  baa,
  gmap,
  hc,
  tdei,
  baaicon: baaIcon,
  gmapicon: gmapIcon,
  hcicon: hcIcon,
  tdeiicon: tdeiIcon,
} as const;

const normalizeImageKey = (value: string) =>
  value
    .trim()
    .replace(/^.*[\\/]/, "")
    .replace(/\.[^/.]+$/, "")
    .toLowerCase();

const normalizedKey = img ? normalizeImageKey(img) : "";
const selectedImage = (imageByKey as Record<string, (typeof baa)>)[normalizedKey];

const normalizedLogoKey = logo ? normalizeImageKey(logo) : "";
const selectedLogo = (imageByKey as Record<string, (typeof baa)>)[normalizedLogoKey];
---

<style>
  time {
    font-size: small;
  }
  .btn {
    background-color: #09638c;
  }
  .btn:hover {
    background-color: #009ad6;
  }
  h2 {
    text-wrap: balance
  }

  .card-wave {
    position: relative;
    display: inline-block;
    overflow: hidden;
    box-shadow: 0 5px 8px rgba(0, 0, 0, 0.3);
    transition: box-shadow 200ms ease-in-out;
    aspect-ratio: 16 / 9;
  }

  .card-wave:hover {
    box-shadow: 0 10px 8px rgba(0, 0, 0, 0.2);
  }

  .card-wave-media {
    position: relative;
    z-index: 1;
    max-height: 256px;

  }

  .card-wave-img {
    display: block;
    width: 100%;
    position: relative;
    z-index: 1;
    transform: scale(1);
    transform-origin: bottom;
    transition: transform 200ms ease-in-out;
  }

  .card-wave:hover .card-wave-img {
    transform: scale(1.05);
  }

  .card-title {
    position: relative;
    z-index: 3;
    color: white;
    font-size: 1.5rem;
    margin: 0;
    text-transform: capitalize;
    text-wrap: balance;
  }

  .front-frame {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 100px;
    width: 100%;
    pointer-events: none;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: end;
    padding: 0 1rem 0.75rem;
  }

  .front-frame::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    clip-path: polygon(100% 100%, 0% 100%, 0% 24.73%, 6.67% 24.25%, 13.33% 22.84%, 20% 20.64%, 26.67% 17.82%, 33.33% 14.62%, 40% 11.33%, 46.67% 8.21%, 53.33% 5.54%, 60% 3.55%, 66.67% 2.4%, 73.33% 2.19%, 80% 2.94%, 86.67% 4.59%, 93.33% 7%, 100% 9.95%);
  }
  
  .front-frame::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    clip-path: polygon(100% 100%, 0% 100%, 0% 9.15%, 6.67% 5.24%, 13.33% 2.14%, 20% .51%, 26.67% .68%, 33.33% 2.61%, 40% 5.91%, 46.67% 9.89%, 53.33% 13.72%, 60% 16.59%, 66.67% 17.91%, 73.33% 17.41%, 80% 15.18%, 86.67% 11.7%, 93.33% 7.69%, 100% 3.98%);
  }

  .front-frame.orangewave::before {
      background: #f7a321;
    }
    .front-frame.orangewave::after {
      background: #e57829;
  }

  .front-frame.bluewave::before {
    background: #2166b2;
  }
  .front-frame.bluewave::after {
    background: #0084c3;
  }

  .front-frame.greenwave::before {
      background: #28b24b;
    }
    .front-frame.greenwave::after {
      background: #b9be33;
  }

  .front-frame.purplewave::before {
    background: #614384;
  }
  .front-frame.purplewave::after {
    background: #8a82a0;
  }
  .logo {
    position: relative;
    z-index: 100;
    margin-left: auto;
    margin-bottom: 0.1rem;
    background-color: white;
    border-radius: .5rem;
    padding: .4rem;
    max-height: 60px;
    width: auto;
  }
  
</style>

     <a href={href} class="card-wave rounded-4">
      <div class="card-wave-media">
        {
          selectedImage ? (
            <Image src={selectedImage} alt={alt} width={560} height={256} class="img-fluid card-wave-img" />
          ) : (
            <img src={img} alt={alt} width={560} height={256} class="img-fluid card-wave-img" />
          )
        }
      </div>
        <div class={`front-frame ${color}`}>
            <h3 class="card-title">{title}</h3>
            {
              selectedLogo ? (
                <Image src={selectedLogo} alt={logo_alt} height={100} class="logo" />
              ) : logo ? (
                <img src={logo} alt={logo_alt} width="auto" height={100} class="logo" />
              ) : null
            }
        </div>
    </a>
