---
import type { ImageMetadata } from "astro";

interface Props {
name: string;
title: string;
contact: string;
profile_image?: string | ImageMetadata;
department: string;
office: string;
class?: string;
}

const {
  name,
  title,
  contact,
  profile_image,
  department,
  office,
    class: className = "",
} = Astro.props;

const profileImageSrc = typeof profile_image === "string" ? profile_image : profile_image?.src;
const initials = name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("");


---

<div class:list={`contact-card ${className}`}>
        {
            profileImageSrc ? (
                <img class="mr-3" src={profileImageSrc} alt={`${name}'s profile picture`} />
            ) : (
                <div class="contact-card-avatar" aria-hidden="true">{initials || "MC"}</div>
            )
        }
    <div>
        <h2>{name}</h2>
        <p>{title}</p>
        <p><i>{department}</i></p>
        <p><i>{office}</i></p>
        <div>
            <a href={`mailto:${contact}`} class="card-link" target="_blank" rel="noopener noreferrer">{contact}</a>
        </div>
    </div>
</div>