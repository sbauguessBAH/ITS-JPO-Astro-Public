---
import PageLayout from "@/src/layouts/PageLayout.astro";
import banner from "@/src/assets/images/banners/NTL_Banner.png";
import NewsroomCard from "@/src/components/NewsroomCard.astro";
import type { NewsroomCardItem } from "@/src/types";
import newsletters from "@/src/content/news-resources/newsletters/newsletters.json";
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";

type NewsletterEntry = {
  title?: string;
  url?: string;
  description?: string;
  date?: string;
  subtitle?: string;
  season?: string;
  volume?: string;
  issue?: string;
  img?: string;
};

type MediaToolkitEntry = {
  title?: string;
  url?: string;
  description?: string;
  date?: string;
  subtitle?: string;
  content_types?: string[];
  topics?: string[];
  location?: string;
};

const keywords = [
  "ITS JPO",
  "newsroom",
  "deployments",
  "conferences",
  "exhibits",
  "newsworthy stories",
  "ITS JPO Now",
  "publications",
];
const description =
  "The ITS JPO Newsroom section contains a variety of information and resources about various deployments, conferences & exhibits, and other newsworthy stories. The ITS JPO Newsroom also archives previous editions of the ITS JPO Now publication. Check back often as this page is regularly updated with new information.";

const newsletterData = newsletters as { newsletters?: NewsletterEntry[] };

const newsletterList: NewsletterEntry[] = Array.isArray(newsletterData.newsletters)
  ? newsletterData.newsletters
  : [];

const toCardItem = (item: NewsletterEntry): NewsroomCardItem => {
  const issueSummary = [item.season, item.volume, item.issue].filter(Boolean).join(" | ");

  return {
    title: item.title,
    url: item.url,
    description: item.description?.trim().length ? item.description : issueSummary,
    date: item.date,
    subtitle: item.subtitle,
  };
};

const featuredNewsletter: NewsroomCardItem | undefined = newsletterList[0]
  ? toCardItem(newsletterList[0])
  : undefined;

const archiveNewsletters: NewsroomCardItem[] = newsletterList
  .slice(1, 5)
  .map((entry) => toCardItem(entry));

const toolkitData = toolkits as { media_toolkits?: MediaToolkitEntry[] };

const mediaToolkits: NewsroomCardItem[] = (Array.isArray(toolkitData.media_toolkits)
  ? toolkitData.media_toolkits
  : [])
  .slice(0, 4)
  .map((item) => ({
    title: item.title,
    url: item.url,
    description: item.description,
    date: item.date,
    subtitle: item.subtitle,
    content_types: item.content_types,
    topics: item.topics,
  }));
---

<PageLayout title="Newsroom" bannerImage={banner} keywords={keywords} description={description}>
  <Fragment slot="banner">Newsroom</Fragment>
  <main>
    <h2 class="sideways blue">ITS JPO Newsroom</h2>
    <div class="container mt-4">
        <div class="row">
            <p class="col-12">
            The ITS JPO Newsroom section contains a variety of information and resources about various deployments, 
            conferences & exhibits, and other newsworthy stories. The ITS JPO Newsroom also archives previous 
            editions of the <i>ITS JPO Now</i> publication. Check back often as this page is regularly updated with 
            new information.
            </p>
      
        </div>
    </div>
    <div class="d-flex justify-content-between mt-5">
        <h2 class="pl-3 heading-border-left blue">Media Kits</h2>
        <a href="./outreach-resources">View All Media Kits</a>
    </div>
    <div class="row gx-4 gy-4 mt-1">
      {
        mediaToolkits.map((mediaKit) => (
          <div class="col-12 col-sm-6 col-xl-3">
            <NewsroomCard item={mediaKit} showPills={true} showColoredLabel={false} ctaText="Read Kit" />
          </div>
        ))
      }
    </div>
    <div class="d-flex justify-content-between mt-5">
        <h2 class="pl-3 heading-border-left blue">ITS JPO Newsletter Archive</h2>
        <a href="./newsletter-archive">Browse Full Archive</a>
    </div>
    <div class="row gx-4 gy-4 mt-1 align-items-stretch newsletter-layout">
      {
        featuredNewsletter && (
            <NewsroomCard
              item={featuredNewsletter}
              class="col-12 col-xl-4 featured-newsletter-col newsletter-card featured-newsletter-card"
              showPills={false}
              showColoredLabel={false}
              ctaText="Read Current Issue"
            />
        )
      }
      <div class="col-12 col-xl-8">
        <div class="row gx-4 gy-4">
          {
            archiveNewsletters.map((newsletter) => (
              <div class="col-12 col-sm-6 archive-newsletter-col">
                <NewsroomCard
                  item={newsletter}
                  showPills={false}
                  showColoredLabel={false}
                  ctaText="Read Issue"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
    </main>
</PageLayout>

<style>
  .featured-newsletter-col {
    display: flex;
  }

  .featured-newsletter-card {
    width: 100%;
  }

  .featured-newsletter-card > .card-body {
    min-height: 100%;
  }

  @media (min-width: 1200px) {
    .featured-newsletter-card {
      min-height: 100%;
    }
  }
</style>
