---
import PageLayout from "@/src/layouts/PageLayout.astro";
import banner from "@/src/assets/images/banners/NTL_Banner.png";
import NewsroomCard from "@/src/components/NewsroomCard.astro";
import base_url from "@/src/lib/base_url";
import type { NewsroomCardItem } from "@/src/types";
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";
import { getCollection } from "astro:content";

type MediaToolkitEntry = {
  title?: string;
  url?: string;
  description?: string;
  date?: string;
  subtitle?: string;
  content_types?: string[];
  topics?: string[];
  location?: string;
};

const keywords = ["ITS JPO", "newsroom", "deployments", "conferences", "exhibits", "newsworthy stories", "ITS JPO Now", "publications"];
const description =
  "The ITS JPO Newsroom section contains a variety of information and resources about various deployments, conferences & exhibits, and other newsworthy stories. The ITS JPO Newsroom also archives previous editions of the ITS JPO Now publication. Check back often as this page is regularly updated with new information.";

const newsletterEntries = (await getCollection("newsletters")).sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const toCardItem = (entry: (typeof newsletterEntries)[number]): NewsroomCardItem => {
  const issueSummary = [entry.data.season, entry.data.volume, entry.data.issue].filter(Boolean).join(" | ");
  const slug = entry.id.replace(/\.(md|mdx)$/i, "");

  return {
    title: entry.data.title,
    url: base_url(`/news-outreach-tools/newsroom/newsletter-archive/${slug}/`),
    description: entry.data.description?.trim().length ? entry.data.description : issueSummary,
    date: entry.data.dateLabel,
    subtitle: entry.data.subtitle,
    imageUrl: entry.data.imageUrl,
    topics: entry.data.topics,
  };
};

const featuredNewsletter: NewsroomCardItem | undefined = newsletterEntries[0] ? toCardItem(newsletterEntries[0]) : undefined;

const archiveNewsletters: NewsroomCardItem[] = newsletterEntries.slice(1, 4).map((entry) => toCardItem(entry));

const toolkitData = toolkits as { media_toolkits?: MediaToolkitEntry[] };

const mediaToolkits: NewsroomCardItem[] = (Array.isArray(toolkitData.media_toolkits) ? toolkitData.media_toolkits : []).slice(0, 4).map((item) => ({
  title: item.title,
  url: item.url,
  description: item.description,
  date: item.date,
  subtitle: item.subtitle,
  content_types: item.content_types,
  topics: item.topics,
}));
---

<PageLayout title="Newsroom" bannerImage={banner} keywords={keywords} description={description}>
  <Fragment slot="banner">Newsroom</Fragment>
  <main>
    
    <div class="row gx-4 gy-4 ">
      <div class="col-12 col-xl-8">
        <h2 class="">ITS JPO Newsroom</h2>
    <p>
      The ITS JPO Newsroom section contains a variety of information and resources about various deployments, conferences & exhibits, and other newsworthy stories. The ITS JPO Newsroom also archives
      previous editions of the <i>ITS JPO Now</i> publication. Check back often as this page is regularly updated with new information.
    </p>
    </div>
    {
      featuredNewsletter && (
        <NewsroomCard
          item={featuredNewsletter}
          class="col-12 col-xl-4 featured-newsletter-col newsletter-card featured-newsletter-card"
          showPills={false}
          showColoredLabel={false}
          showImage={false}
          ctaText="Read Current Issue"
        />
      )
    }
    </div>

    <div class="d-flex justify-content-between mt-5">
      <h2 class="pl-3 heading-border-left blue">Media Kits</h2>
      <a href={base_url("/news-outreach-tools/newsroom/outreach-resources/")}>View All Media Kits</a>
    </div>
    <div class="row gx-4 gy-4 mt-1">
      {
        mediaToolkits.map((mediaKit) => (
          <div class="col-12 col-sm-6 col-xl-3">
            <NewsroomCard item={mediaKit} showPills={true} showColoredLabel={false} ctaText="Read Kit" />
          </div>
        ))
      }
    </div>
    <div class="d-flex justify-content-between mt-5">
      <h2 class="pl-3 heading-border-left blue">ITS JPO Newsletter Archive</h2>
      <a href={base_url("/news-outreach-tools/newsroom/newsletter-archive/")}>Browse Full Archive</a>
    </div>
    <div class="row gx-4 gy-4 mt-1 align-items-stretch newsletter-layout">
      {
        featuredNewsletter && (
          <NewsroomCard
            item={featuredNewsletter}
            class="col-12 col-xl-4 featured-newsletter-col newsletter-card featured-newsletter-card"
            showPills={false}
            showColoredLabel={false}
            showImage={true}
            ctaText="Read Current Issue"
          />
        )
      }
      <div class="col-12 col-xl-8">
        <div class="row gx-4 gy-4">
          {
            archiveNewsletters.map((newsletter) => (
              <div class="col-12 col-sm-4 archive-newsletter-col">
                <NewsroomCard item={newsletter} showPills={true} showColoredLabel={false} showImage={true} ctaText="Read Issue" />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </main>
</PageLayout>

<style>
  .heading-border-left.blue {
    padding: 0 0 0 0.6rem;
    line-height: 1.5rem;
    font-size: 1.75rem;
    border-left: 5px solid;
    border-color: #055581;
    border-bottom: none;
  }
  .featured-newsletter-col {
    display: flex;
  }

  .featured-newsletter-card {
    width: 100%;
  }

  .featured-newsletter-card > .card-body {
    min-height: 100%;
  }

  @media (min-width: 1200px) {
    .featured-newsletter-card {
      min-height: 100%;
    }
  }
</style>
