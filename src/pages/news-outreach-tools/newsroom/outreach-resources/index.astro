---
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";
import webinars from "@/src/content/news-resources/webinars/webinars.json";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import NewsroomCard from "@/src/components/NewsroomCard.astro";
import WebinarCard from "@/src/components/WebinarCard.astro";
import type { NewsroomCardItem, Toolkit } from "@/src/types";

type WebinarEntry = {
  title?: string;
  recordingLink?: string;
  slidesLink?: string;
  description?: string;
  date?: string;
  subtitle?: string;
  duration?: string;
};

const toolkitData = toolkits as {
  outreach_toolkits?: Toolkit[];
  media_toolkits?: Toolkit[];
};

const webinarData = webinars as {
  webinars?: WebinarEntry[];
};

const allToolkits: Toolkit[] = [
  ...(Array.isArray(toolkitData?.outreach_toolkits) ? toolkitData.outreach_toolkits : []),
  ...(Array.isArray(toolkitData?.media_toolkits) ? toolkitData.media_toolkits : []),
];

const toolkitList: NewsroomCardItem[] = allToolkits.map((toolkit) => ({
  title: toolkit.title,
  url: toolkit.url,
  description: toolkit.description,
  date: toolkit.date,
  subtitle: toolkit.subtitle,
  content_types: toolkit.content_types,
  topics: toolkit.topics,
}));

const toolkitPageSize = 9;

const uniqueStrings = (values: Array<string | undefined | null>): string[] => {
  return [...new Set(values.filter((v): v is string => typeof v === "string" && v.trim().length > 0))];
};

const contentTypes = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.content_types ?? []));
const topics = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.topics ?? []));

const webinarList: Required<WebinarEntry>[] = (Array.isArray(webinarData?.webinars) ? webinarData.webinars : []).map((webinar) => ({
  title: webinar.title ?? "",
  recordingLink: webinar.recordingLink ?? "",
  slidesLink: webinar.slidesLink ?? "",
  description: webinar.description ?? "",
  date: webinar.date ?? "",
  subtitle: webinar.subtitle ?? "",
  duration: webinar.duration ?? "",
}));

const slugifyForId = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
---

<BaseLayout title="filter" description="Filter news content by type and topic." keywords={"filter"}>
  <main class="container my-5">
    <h1 class="h2 mb-4 sideways blue">Outreach Resources</h1>
    <p></p>
    <h2 class="heading-border-left blue">All Toolkits</h2>
    <form class="row g-4 reduced-gutters filter mb-4 p-3" aria-label="News filter">
      <div class="col-12 col-lg-6">
        <label class="form-label" for="content-type-toggle">Content Type</label>
        <div class="dropdown multi-select-dropdown">
          <button id="content-type-toggle" type="button" class="dropdown-toggle w-100 text-start" aria-haspopup="listbox" aria-expanded="false">
            <span class="dropdown-label">Select content types</span>
          </button>
          <div class="dropdown-menu w-100 p-2" aria-labelledby="content-type-toggle" role="listbox" id="content-type-list" style="max-height: 240px; overflow:auto;">
            {
              contentTypes.map((type) => {
                const id = `content-type-${slugifyForId(type)}`;
                return (
                  <div class="content-type-option">
                    <input class="visually-hidden content-type-input" type="checkbox" id={id} name="content-type" value={type} />
                    <label class="content-type-label" for={id}>
                      {type.charAt(0).toUpperCase() + type.slice(1)}
                    </label>
                  </div>
                );
              })
            }
          </div>
        </div>
        <div class="form-text">Click to open, then check items to select multiple.</div>
      </div>

      <fieldset class="col-12 col-lg-6">
        <legend class="col-form-label pt-0">Topics</legend>
        <div class="topic-pills">
          {
            topics.map((topic) => {
              const topicId = `topic-${slugifyForId(topic)}`;
              return (
                <div class="topic-pill-option">
                  <input class="visually-hidden topic-input" type="checkbox" id={topicId} name="topic" value={topic} />
                  <label class="topic-pill" for={topicId}>
                    {topic.charAt(0).toUpperCase() + topic.slice(1)}
                  </label>
                </div>
              );
            })
          }
        </div>
      </fieldset>
    </form>
    <div id="toolkit-cards" class="row gx-4 gy-4">
      {
        toolkitList.map((toolkit) => (
          <div class="col-12 col-md-4 toolkit-card-col">
            <NewsroomCard item={toolkit} showPills={true} showSubtitle={false} pillSource="content_types" showColoredLabel={true} ctaText="Read Kit" />
          </div>
        ))
      }
    </div>
    <p id="toolkit-empty-state" class="toolkit-empty-state" hidden>No toolkits match the selected filters.</p>
    <nav id="toolkit-pagination" class="toolkit-pagination" aria-label="Toolkit pagination" hidden>
      <button id="toolkit-pagination-prev" type="button" class="toolkit-pagination-button">
        Previous
      </button>
      <div id="toolkit-pagination-pages" class="toolkit-pagination-pages"></div>
      <button id="toolkit-pagination-next" type="button" class="toolkit-pagination-button">
        Next
      </button>
    </nav>
    <div>
        <h2 class="heading-border-left blue mt-4">Webinar Archives</h2>
        <p></p>
        <div class="row gx-4 gy-4">
          {
            webinarList.map((webinar) => (
              <div class="col-12 col-md-6 col-xl-4">
                <WebinarCard
                  date={webinar.date}
                  subtitle={webinar.subtitle}
                  title={webinar.title}
                  description={webinar.description}
                  duration={webinar.duration}
                  recordingLink={webinar.recordingLink}
                  slidesLink={webinar.slidesLink}
                />
              </div>
            ))
          }
        </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ toolkitList, toolkitPageSize }}>
  const dropdownToggle = document.getElementById("content-type-toggle");
  const dropdownMenu = document.getElementById("content-type-list");
  const toolkitCols = Array.from(document.querySelectorAll("#toolkit-cards .toolkit-card-col"))
    .filter((el) => el instanceof HTMLElement);
  const paginationNav = document.getElementById("toolkit-pagination");
  const paginationPrev = document.getElementById("toolkit-pagination-prev");
  const paginationNext = document.getElementById("toolkit-pagination-next");
  const paginationPages = document.getElementById("toolkit-pagination-pages");
  const emptyState = document.getElementById("toolkit-empty-state");
  let currentPage = 1;

  const updateDropdownLabel = () => {
    const selected = Array.from(document.querySelectorAll('input[name="content-type"]:checked'))
      .filter((el) => el instanceof HTMLInputElement)
      .map((cb) => {
        const label = document.querySelector(`label[for="${cb.id}"]`);
        return label?.textContent?.trim() || cb.value;
      });
    const labelEl = document.querySelector("#content-type-toggle .dropdown-label");
    if (!labelEl) return;
    labelEl.textContent = selected.length === 0 ? "Select content types" : selected.join(", ");
  };

  const getSelectedContentTypes = () =>
    Array.from(document.querySelectorAll('input[name="content-type"]:checked'))
      .filter((el) => el instanceof HTMLInputElement)
      .map((cb) => cb.value);

  const getCheckedTopics = () =>
    Array.from(document.querySelectorAll('input[name="topic"]:checked'))
      .filter((el) => el instanceof HTMLInputElement)
      .map((cb) => cb.value);

  const getFilteredIndexes = (selectedContentTypes, selectedTopics) => {
    return toolkitList.reduce((indexes, toolkit, index) => {
      const hasContentType = selectedContentTypes.length === 0 || (toolkit.content_types ?? []).some((ct) => selectedContentTypes.includes(ct));
      const hasTopic = selectedTopics.length === 0 || (toolkit.topics ?? []).some((topic) => selectedTopics.includes(topic));
      if (hasContentType && hasTopic) {
        indexes.push(index);
      }
      return indexes;
    }, []);
  };

  const renderPagination = (matchCount) => {
    const pageCount = Math.ceil(matchCount / toolkitPageSize);

    if (paginationNav instanceof HTMLElement) {
      paginationNav.hidden = pageCount <= 1;
    }

    if (!(paginationPages instanceof HTMLElement)) {
      return;
    }

    paginationPages.replaceChildren();

    for (let pageNumber = 1; pageNumber <= pageCount; pageNumber += 1) {
      const pageButton = document.createElement("button");
      pageButton.type = "button";
      pageButton.className = `toolkit-pagination-button${pageNumber === currentPage ? " is-active" : ""}`;
      pageButton.textContent = `${pageNumber}`;
      pageButton.setAttribute("aria-label", `Go to page ${pageNumber}`);
      pageButton.setAttribute("aria-current", pageNumber === currentPage ? "page" : "false");
      pageButton.addEventListener("click", () => {
        currentPage = pageNumber;
        runFilter({ resetPage: false });
      });
      paginationPages.append(pageButton);
    }

    if (paginationPrev instanceof HTMLButtonElement) {
      paginationPrev.disabled = currentPage <= 1;
    }

    if (paginationNext instanceof HTMLButtonElement) {
      paginationNext.disabled = currentPage >= pageCount;
    }
  };

  const applyToDOM = (matchingIndexes) => {
    const pageCount = Math.ceil(matchingIndexes.length / toolkitPageSize);

    if (pageCount > 0 && currentPage > pageCount) {
      currentPage = pageCount;
    }

    const startIndex = (currentPage - 1) * toolkitPageSize;
    const visibleIndexes = new Set(matchingIndexes.slice(startIndex, startIndex + toolkitPageSize));

    toolkitCols.forEach((col, index) => {
      col.style.display = visibleIndexes.has(index) ? "" : "none";
    });

    if (emptyState instanceof HTMLElement) {
      emptyState.hidden = matchingIndexes.length > 0;
    }

    renderPagination(matchingIndexes.length);
  };

  const runFilter = ({ resetPage = true } = {}) => {
    const selectedContentTypes = getSelectedContentTypes();
    const checkedTopics = getCheckedTopics();

    if (resetPage) {
      currentPage = 1;
    }

    applyToDOM(getFilteredIndexes(selectedContentTypes, checkedTopics));
    updateDropdownLabel();
  };

  const toggleDropdown = (show) => {
    const expanded = typeof show === "boolean" ? show : !(dropdownToggle?.getAttribute("aria-expanded") === "true");
    dropdownToggle?.setAttribute("aria-expanded", expanded ? "true" : "false");
    if (dropdownMenu) {
      if (expanded) dropdownMenu.classList.add("show");
      else dropdownMenu.classList.remove("show");
    }
  };

  dropdownToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    toggleDropdown();
  });

  // close when clicking outside
  document.addEventListener("click", (e) => {
    const target = e.target;
    if (!dropdownMenu?.contains(target) && !dropdownToggle?.contains(target)) {
      toggleDropdown(false);
    }
  });

  // keyboard: close on Escape
  dropdownToggle?.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      toggleDropdown(false);
      dropdownToggle.focus();
    }
  });

  // listen to content-type checkbox changes
  Array.from(document.querySelectorAll('input[name="content-type"]')).forEach((el) => {
    el.addEventListener("change", () => runFilter());
  });

  document.querySelectorAll('input[name="topic"]').forEach((el) => {
    el.addEventListener("change", runFilter);
  });

  paginationPrev?.addEventListener("click", () => {
    if (currentPage > 1) {
      currentPage -= 1;
      runFilter({ resetPage: false });
    }
  });

  paginationNext?.addEventListener("click", () => {
    currentPage += 1;
    runFilter({ resetPage: false });
  });

  // initialize
  updateDropdownLabel();
  runFilter();
</script>

<style>
  .reduced-gutters {
    --bs-gutter-x: 14px;
  }

  .filter {
    background-color: var(--bs-light);
    border: 1px solid var(--bs-border-color);
    border-radius: 12px;
  }

  .topic-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .topic-pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid grey;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    line-height: 1.2;
    cursor: pointer;
    user-select: none;
    background-color: white;
    color: black;
  }

  .topic-pill-option > input:checked + .topic-pill {
    background-color: var(--bs-primary);
    border-color: var(--bs-primary);
    color: var(--bs-white);
  }

  .topic-pill-option > input:focus-visible + .topic-pill {
    outline: 0;
    box-shadow: 0 0 0 0.25rem rgba(var(--bs-primary-rgb), 0.25);
  }

  .content-type-option {
    display: flex;
  }

  .content-type-label {
    width: 100%;
    padding: 0.375rem 0.5rem;
    border-radius: 0.25rem;
    cursor: pointer;
    user-select: none;
  }

  .content-type-option > input:checked + .content-type-label {
    color: var(--bs-primary);
    font-weight: 600;
    background-color: var(--bs-primary-bg-subtle);
  }

  .content-type-option > input:focus-visible + .content-type-label {
    outline: 0;
    box-shadow: 0 0 0 0.25rem rgba(var(--bs-primary-rgb), 0.25);
  }
  
  .dropdown-toggle {
    display: flex;
    background-color: #fff;
    border: 1px solid #ced4da;
    border-radius: 0.25rem;
    align-items: center;
  }
  .dropdown-toggle:focus {
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
  }

  .multi-select-dropdown .dropdown-menu {
    display: none;
  }
  .multi-select-dropdown .dropdown-menu.show {
    display: block;
  }
  .multi-select-dropdown .dropdown-label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: inline-block;
    max-width: 100%;
  }
.dropdown-toggle:after{
    content: '\f078';
    font-family: FontAwesome;
    font-size:16px;
}

  .toolkit-empty-state {
    margin-top: 1.5rem;
    color: #6c757d;
  }

  .toolkit-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .toolkit-pagination-pages {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .toolkit-pagination-button {
    min-width: 2.75rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid #ced4da;
    border-radius: 999px;
    background-color: #fff;
    color: #055681;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .toolkit-pagination-button:hover:not(:disabled),
  .toolkit-pagination-button:focus-visible {
    border-color: #055681;
    background-color: #e8f1f9;
    outline: 0;
  }

  .toolkit-pagination-button.is-active {
    border-color: #055681;
    background-color: #055681;
    color: #fff;
  }

  .toolkit-pagination-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }


</style>
