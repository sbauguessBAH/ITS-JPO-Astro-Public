---
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";
import BaseLayout from "@/src/layouts/BaseLayout.astro";

type Toolkit = {
  content_types?: string[];
  topics?: string[];
  title?: string;
  url?: string;
  description?: string;
  last_updated?: string;
  toolkit_type?: string;
};

const toolkitData = toolkits as {
  outreach_toolkits?: Toolkit[];
};

const toolkitList: Toolkit[] = [
  ...(Array.isArray(toolkitData?.outreach_toolkits) ? toolkitData.outreach_toolkits : []),
];

const uniqueStrings = (values: Array<string | undefined | null>): string[] => {
  return [...new Set(values.filter((v): v is string => typeof v === "string" && v.trim().length > 0))];
};

const contentTypes = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.content_types ?? []));
const topics = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.topics ?? []));

const slugifyForId = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
---

<BaseLayout title="filter" description="Filter news content by type and topic." keywords={"filter"}>
  <main class="container my-5">
    <h1 class="h2 mb-4">News Filter</h1>

    <form class="row g-4 reduced-gutters" aria-label="News filter">
      <div class="col-12 col-lg-6">
        <label class="form-label" for="content-type-toggle">Content Type</label>
        <div class="dropdown multi-select-dropdown">
          <button id="content-type-toggle" type="button" class="dropdown-toggle w-100 text-start" aria-haspopup="listbox" aria-expanded="false">
            <span class="dropdown-label">Select content types</span>
          </button>
          <div class="dropdown-menu w-100 p-2" aria-labelledby="content-type-toggle" role="listbox" id="content-type-list" style="max-height: 240px; overflow:auto;">
            {
              contentTypes.map((type) => {
                const id = `content-type-${slugifyForId(type)}`;
                return (
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id={id} name="content-type" value={type} />
                    <label class="form-check-label" for={id}>
                      {type.charAt(0).toUpperCase() + type.slice(1)}
                    </label>
                  </div>
                );
              })
            }
          </div>
        </div>
        <div class="form-text">Click to open, then check items to select multiple.</div>
      </div>

      <fieldset class="col-12 col-lg-6">
        <legend class="col-form-label pt-0">Topics</legend>
        <div class="topic-list">
          {
            topics.map((topic) => {
              const topicId = `topic-${slugifyForId(topic)}`;
              return (
                <div class="form-check rounded-pill">
                  <input class="form-check-input" type="checkbox" id={topicId} name="topic" value={topic} />
                  <label class="form-check-label" for={topicId}>
                    {topic.charAt(0).toUpperCase() + topic.slice(1)}
                  </label>
                </div>
              );
            })
          }
        </div>
      </fieldset>
    </form>
    <div id="toolkit-cards" class="row gx-4 gy-4">
      {
        toolkitList.map((toolkit) => (
          <div class="col-12 col-md-4 toolkit-card-col">
            <div class="card h-100 toolkit-card">
              <div class="card-body">
                <h5 class="card-title">{toolkit.title}</h5>
                {(toolkit.description || toolkit.last_updated) && (
                  <p class="card-text">
                    {toolkit.description ?? ""}
                    {!toolkit.description && toolkit.last_updated && (
                      <>
                        {[toolkit.last_updated].filter(Boolean).join(" — ")}
                      </>
                    )}
                  </p>
                )}
                {toolkit.url && (
                  <a href={toolkit.url} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                    View Toolkit
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </main>
</BaseLayout>

<script define:vars={{ toolkitList }}>
  const dropdownToggle = document.getElementById("content-type-toggle");
  const dropdownMenu = document.getElementById("content-type-list");

  const updateDropdownLabel = () => {
    const selected = Array.from(document.querySelectorAll('input[name="content-type"]:checked')).map((el) => el.value);
    const labelEl = document.querySelector("#content-type-toggle .dropdown-label");
    if (!labelEl) return;
    labelEl.textContent = selected.length === 0 ? "Select content types" : selected.join(", ");
  };

  const getSelectedContentTypes = () =>
    Array.from(document.querySelectorAll('input[name="content-type"]:checked'))
      .filter((el) => el instanceof HTMLInputElement)
      .map((cb) => cb.value);

  const getCheckedTopics = () =>
    Array.from(document.querySelectorAll('input[name="topic"]:checked'))
      .filter((el) => el instanceof HTMLInputElement)
      .map((cb) => cb.value);

  const getFilteredMatches = (selectedContentTypes, selectedTopics) => {
    return toolkitList.map((toolkit) => {
      const hasContentType = selectedContentTypes.length === 0 || (toolkit.content_types ?? []).some((ct) => selectedContentTypes.includes(ct));
      const hasTopic = selectedTopics.length === 0 || (toolkit.topics ?? []).some((topic) => selectedTopics.includes(topic));
      return hasContentType && hasTopic;
    });
  };

  const applyToDOM = (matches) => {
    const cols = document.querySelectorAll("#toolkit-cards .toolkit-card-col");
    cols.forEach((col, index) => {
      col.style.display = matches[index] ? "" : "none";
    });
  };

  const runFilter = () => {
    const selectedContentTypes = getSelectedContentTypes();
    const checkedTopics = getCheckedTopics();
    applyToDOM(getFilteredMatches(selectedContentTypes, checkedTopics));
    updateDropdownLabel();
  };

  const toggleDropdown = (show) => {
    const expanded = typeof show === "boolean" ? show : !(dropdownToggle?.getAttribute("aria-expanded") === "true");
    dropdownToggle?.setAttribute("aria-expanded", expanded ? "true" : "false");
    if (dropdownMenu) {
      if (expanded) dropdownMenu.classList.add("show");
      else dropdownMenu.classList.remove("show");
    }
  };

  dropdownToggle?.addEventListener("click", (e) => {
    e.stopPropagation();
    toggleDropdown();
  });

  // close when clicking outside
  document.addEventListener("click", (e) => {
    const target = e.target;
    if (!dropdownMenu?.contains(target) && !dropdownToggle?.contains(target)) {
      toggleDropdown(false);
    }
  });

  // keyboard: close on Escape
  dropdownToggle?.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      toggleDropdown(false);
      dropdownToggle.focus();
    }
  });

  // listen to content-type checkbox changes
  Array.from(document.querySelectorAll('input[name="content-type"]')).forEach((el) => {
    el.addEventListener("change", () => runFilter());
  });

  document.querySelectorAll('input[name="topic"]').forEach((el) => {
    el.addEventListener("change", runFilter);
  });

  // initialize
  updateDropdownLabel();
  runFilter();
</script>

<style>
  .reduced-gutters {
    --bs-gutter-x: 14px;
  }
  
  .dropdown-toggle {
    display: flex;
    background-color: #fff;
    border: 1px solid #ced4da;
    border-radius: 0.25rem;
    align-items: center;
  }
  .dropdown-toggle:focus {
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
  }

  .multi-select-dropdown .dropdown-menu {
    display: none;
  }
  .multi-select-dropdown .dropdown-menu.show {
    display: block;
  }
  .multi-select-dropdown .dropdown-label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: inline-block;
    max-width: 100%;
  }
.dropdown-toggle:after{
    content: '\f078';
    font-family: FontAwesome;
    font-size:16px;
}


</style>
