---
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import ContactCard from "@/src/components/toolkits/ContactCard.astro";
import ResourceCard from "@/src/components/toolkits/ResourceCard.astro";
import "@/src/styles/toolkits.css";

---

<BaseLayout
  title="Transportation Research Board (TRB) Annual Meeting 2026"
  description="Resources to help communities and agencies communicate the benefits of V2X technology to local stakeholders and the public."
  keywords={"TRB"}
>
  <main class="container my-5 toolkit-page">
    <div class="toolkit-header">
      <h1 class="h2 mb-4 sideways blue">NEWSROOM</h1>
      <h2 class="sideways blue kit-page-title">Transportation Research Board (TRB) Annual Meeting 2026</h2>
    </div>

    <section class="kit-section contacts">
      <h3>Contacts</h3>
      <div class="kit-grid kit-card-grid">
        <ContactCard
          name="Jane Doe"
          profile_image="/images/jane-doe.jpg"
          title="Public Affairs Specialist"
          office="ITS JPO"
          department="Public Affairs"
          contact="test@dot.gov"
        />
        <ContactCard
          name="Jane Doe"
          profile_image="/images/jane-doe.jpg"
          title="Public Affairs Specialist"
          office="ITS JPO"
          department="Public Affairs"
          contact="test@dot.gov"
        />
      </div>
    </section>

    <section class="kit-section resources">
      <h3>ITS JPO Resources Distributed at TRB 2026</h3>
      <div class="kit-grid kit-card-grid">
        <ResourceCard
          title="Fact Sheet: Connected Vehicle Technology"
          type="Fact Sheet"
          date="January 2026"
          link="https://www.its.dot.gov/factsheets/pdf/connected_vehicle.pdf"
        />
        <ResourceCard
          title="Infographic: Benefits of V2X Technology"
          type="Infographic"
          date="January 2026"
          link="https://www.its.dot.gov/infographics/pdf/v2x_benefits.pdf"
        />
      </div>
    </section>

    <section class="kit-section social-posts">
      <h3>Social Posts</h3>
      <div class="kit-grid" data-empty-label="Add approved posts, captions, or short event copy here."></div>
    </section>

    <section class="kit-section infographics">
      <h3>Infographics</h3>
      <div class="kit-grid" data-empty-label="Add static graphics, handouts, or downloadable one-page visuals here."></div>
    </section>

    <section class="kit-section slides">
      <h3>Slides</h3>
      <div class="kit-grid" data-empty-label="Add presentation decks, speaker slides, or briefing materials here."></div>
    </section>
  </main>
</BaseLayout>
