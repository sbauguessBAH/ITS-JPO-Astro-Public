---
import PageLayout from "@/src/layouts/PageLayout.astro";
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";

const contentTypes = Array.from(toolkits.flatMap(toolkit => toolkit["content_types"])).filter((value, index, self) => self.indexOf(value) === index);
const allContentTypes = Array.from(
  new Set(toolkits.flatMap((t) => t.content_types ?? []))
).sort((a, b) => a.localeCompare(b));
