---
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";
import BaseLayout from "@/src/layouts/BaseLayout.astro";

type Toolkit = {
  content_types?: string[];
  topics?: string[];
  title?: string;
  url?: string;
  description?: string;
};

const toolkitList: Toolkit[] = Array.isArray(toolkits) ? (toolkits as Toolkit[]) : [];

const uniqueStrings = (values: Array<string | undefined | null>): string[] => {
  return [...new Set(values.filter((v): v is string => typeof v === "string" && v.trim().length > 0))];
};

const contentTypes = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.content_types ?? []));
const topics = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.topics ?? []));

const slugifyForId = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
---
<BaseLayout title="filter" description="Filter news content by type and topic." keywords={"filter"}>
  <main class="container my-5">
    <h1 class="h2 mb-4">News Filter</h1>

    <form class="row g-4" aria-label="News filter">
      <div class="col-12 col-lg-6">
        <label class="form-label" for="content-type">Content Type</label>
        <select id="content-type" name="content-type" class="form-select" multiple size={Math.min(10, Math.max(4, contentTypes.length))}>
          {contentTypes.map((type) => (
            <option value={type}>{type}</option>
          ))}
        </select>
        <div class="form-text">Hold Ctrl (Windows) or Cmd (Mac) to select multiple.</div>
      </div>

      <fieldset class="col-12 col-lg-6">
        <legend class="col-form-label pt-0">Topics</legend>
        <div class="topic-list">
          {topics.map((topic) => {
            const topicId = `topic-${slugifyForId(topic)}`;
            return (
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id={topicId} name="topic" value={topic} />
                <label class="form-check-label" for={topicId}>{topic}</label>
              </div>
            );
          })}
        </div>
      </fieldset>
    </form>
    <div>
      {toolkitList.map((toolkit) => (
        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title">{toolkit.title}</h5>
            <p class="card-text">{toolkit.description}</p>
            {toolkit.url && (
              <a href={toolkit.url} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                View Toolkit
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </main>
  </BaseLayout>

  <script define:vars={{toolkitList}}>
    document.getElementById("content-type")?.addEventListener("change", (event) => {
      const selectedOptions = Array.from((event.target).selectedOptions).map((option) => option.value);
      getFilteredCards(selectedOptions, Array.from(document.querySelectorAll<HTMLInputElement>('input[name="topic"]:checked')).map((cb) => cb.value));
    });
    const topicCheckboxes = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="topic"]'));
    topicCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", (event) => {
        console.log("hi","Topic changed:", (event.target).value, "checked:", (event.target).checked);
        const checkedTopics = topicCheckboxes.filter((cb) => cb.checked).map((cb) => cb.value);
        const selectedContentTypes = Array.from(document.getElementById("content-type")?.selectedOptions ?? []).map((option) => option.value);
        console.log("hi","Selected Content Types:", selectedContentTypes);
        getFilteredCards(selectedContentTypes, checkedTopics);
      });
    });
    
    const getFilteredCards = (selectedContentTypes, selectedTopics) => {
      console.log("hi","Filtering cards with Content Types:", selectedContentTypes, "Topics:", selectedTopics);
      const filteredToolkits = toolkitList.filter((toolkit) => {
        const hasContentType = selectedContentTypes.length === 0 || (toolkit.content_types ?? []).some((ct) => selectedContentTypes.includes(ct));
        const hasTopic = selectedTopics.length === 0 || (toolkit.topics ?? []).some((topic) => selectedTopics.includes(topic));
        return hasContentType && hasTopic;
        
      });
      applyToDOM(filteredToolkits);
    }

    const applyToDOM = (filteredToolkits) => {
      const cards = document.querySelectorAll("main > div > .card");

      cards.forEach((card, index) => {
        if (filteredToolkits[index]) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });

    }
  </script>