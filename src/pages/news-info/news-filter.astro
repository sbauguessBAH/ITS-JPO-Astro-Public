---
import PageLayout from "@/src/layouts/PageLayout.astro";
import toolkits from "@/src/content/news-resources/toolkits/toolkits.json";

type Toolkit = {
  content_types?: string[];
  topics?: string[];
  title?: string;
  url?: string;
  description?: string;
};

const toolkitList: Toolkit[] = Array.isArray(toolkits) ? (toolkits as Toolkit[]) : [];

const uniqueStrings = (values: Array<string | undefined | null>): string[] => {
  return [...new Set(values.filter((v): v is string => typeof v === "string" && v.trim().length > 0))];
};

const contentTypes = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.content_types ?? []));
const topics = uniqueStrings(toolkitList.flatMap((toolkit) => toolkit.topics ?? []));

const slugifyForId = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
---

  <main class="container my-5">
    <h1 class="h2 mb-4">News Filter</h1>

    <form class="row g-4" aria-label="News filter">
      <div class="col-12 col-lg-6">
        <label class="form-label" for="content-type">Content Type</label>
        <select id="content-type" name="content-type" class="form-select" multiple size={Math.min(10, Math.max(4, contentTypes.length))}>
          {contentTypes.map((type) => (
            <option value={type}>{type}</option>
          ))}
        </select>
        <div class="form-text">Hold Ctrl (Windows) or Cmd (Mac) to select multiple.</div>
      </div>

      <fieldset class="col-12 col-lg-6">
        <legend class="col-form-label pt-0">Topics</legend>
        <div class="topic-list">
          {topics.map((topic) => {
            const topicId = `topic-${slugifyForId(topic)}`;
            return (
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id={topicId} name="topic" value={topic} />
                <label class="form-check-label" for={topicId}>{topic}</label>
              </div>
            );
          })}
        </div>
      </fieldset>
    </form>
    <div>

    </div>
  </main>