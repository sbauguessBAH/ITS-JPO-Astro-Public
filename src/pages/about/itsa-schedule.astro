---
import PageLayout from "@/src/layouts/PageLayout.astro";

const keywords = ["ITS America", "ITSA 2026", "conference", "schedule", "Detroit", "V2X", "ITS JPO", "intelligent transportation systems", "event"];

const description = "ITS JPO activities schedule at ITS America Conference & Expo 2026 in Detroit, June 9-12. Find featured speakers, sessions, and booth information.";
---

<PageLayout title="ITSA 2026 Schedule - ITS Joint Program Office" keywords={keywords} description={description}>
  <Fragment slot="banner">ITSA 2026 Schedule</Fragment>

  <main>
    <h2>Where to Find ITS JPO at ITS America Conference & Expo 2026</h2>

    <section class="mb-5">
      <p>Attendees at the ITS America Conference & Expo (ITSA) in Detroit, Mich., June 9–12, 2026, will have many opportunities to learn about ITS JPO activities. Featured speakers will include:</p>

      <ul class="mb-4">
        <li>
          <strong>Justin Anderson</strong>, "From Concept to Curbside: Insights from the V2X Accelerator Deployments on the Road to Interoperability," <span class="text-muted">
            Tuesday, June 9 at 1 p.m.
          </span>
        </li>
        <li>
          <strong>Elina Zlotchenko</strong>, "Paving the Path to the Complete Trip: Next-Generation Mobility, Accessibility, and the Road Ahead," <span class="text-muted">
            Tuesday, June 9 at 2:30 p.m.
          </span>
        </li>
        <li><strong>Hyungjun Park</strong>, "Beyond Line of Sight - Harmonizing Connectivity and Automation in Autonomous Freight," <span class="text-muted">Thursday, June 11 at 10:30 a.m.</span></li>
        <li><strong>Lisa Randall</strong>, "Bridging the Gap: USDOT Resources for Trustworthy AI Implementations," <span class="text-muted">Thursday, June 11 at 1 p.m.</span></li>
        <li><strong>Justin Anderson</strong>, "A Digital Seatbelt: Interoperable V2X Traveler Information Messages," <span class="text-muted">Friday, June 12 at 1 p.m.</span></li>
      </ul>

      <h2 class="text-center">Engage with the Leaders</h2>
      <div class="row gap-4 justify-content-center">
        <div class="col-md-5 text-center justify-content-center align-items-center card p-4 m-0 rounded-4 gradent-bg">
          <div class="booth-id">
                <p class="text-yellow">Booth 4031</p>
              </div>
          <h4 class="text-center">Artificial Intelligence Deployment Center of Excellence (AI COE)</h4>
          <p class="text-center">Office Hours</p>
          <table>
            <tbody>
              <tr>
                <td><strong>Wednesday</strong>, June 10</td>
                <td>1:00 - 2:00 PM</td>
              </tr>
              
              <tr>
                <td><strong>Thursday</strong>, June 11</td>
                <td>10:30 - 11:30 AM</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="col-md-5 content-card p-4 card rounded-4 gradent-bg">
          <div class="booth-id">
                <p class="text-yellow">Booth 4031</p>
              </div>
          <h4 class="text-center">Topic Hours</h4>
          <p class="text-center">Thursday, June 11</p>
          
          <table>
            <tbody>
              <tr>
                <td class="align-top">1:00 - 2:00 PM</td>
                <td class="text-start">
                  <p class="mb-0"><strong>Accelerating V2X Deployment</strong></p>
                  <p class="mb-0 fs-6"><span class="text-yellow">JD Schneeberger,</span> ITS JPO</p>
                  <p class="mb-0 fs-6"><span class="text-yellow">Govind Vadakpat,</span> FHWA</p>
                  <p class="mb-0 fs-6"><span class="text-yellow">Usman Ali,</span> FHWA</p>
                </td>
              </tr>
              <tr>
                <td class="align-top">2:00 - 3:00 PM</td>
                <td class="text-start">
                  <p class="mb-0"><strong>Connected Automated Vehicles</strong></p>
                  <p class="mb-0 fs-6"><span class="text-yellow">Hyungjun Park,</span> ITS JPO</p>
                  <p class="mb-0 fs-6"><span class="text-yellow">Justin Anderson,</span> ITS JPO</p>
                  <p class="mb-0 fs-6"><span class="text-yellow">J.D. Schneeberger</span> ITS JPO</p>
                </td>
              </tr>
              <tr>
                <td class="align-top">3:00 - 4:00 PM</td>
                <td class="text-start">
                  <p class="mb-0"><strong>AI Transportation Solutions</strong></p>
                  <p class="mb-0 fs-6"><span class="text-yellow">Lisa Randall,</span> ITS JPO</p>
                  <p class="mb-0 fs-6"><span class="text-yellow">Bob Sheehan,</span> FHWA</p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <section class="schedule-section">
          <h2 class="mb-4">Complete Schedule of US DOT Activities</h2>

          <div class="responsive-table">
            <table class="table table-bordered  schedule-table mb-5">
              <thead class="table-dark">
                <tr>
                  <th scope="col">Time</th>
                  <th scope="col">Room</th>
                  <th scope="col">Event Name</th>
                  <th scope="col">USDOT Representative</th>
                </tr>
              </thead>
              <tbody>
                <tr class="table-primary">
                  <th scope="row" colspan="4" class="day-header">Tuesday, June 9</th>
                </tr>
                <tr>
                  <td>1-2pm</td>
                  <td>330A</td>
                  <td>SIS68: From Concept to Curbside: Insights from the V2X Accelerator Deployments On the Road to Interoperability</td>
                  <td><ul><li>Govind Vadakpat</li><li>Danielle Chou</li><li>Justin Anderson</li></ul></td>
                </tr>
                <tr>
                  <td>2:30-3:30pm</td>
                  <td>330A</td>
                  <td>SIS71: Paving the Path to the Complete Trip: Next-Generation Mobility, Accessibility, and the Road Ahead</td>
                  <td><ul><li>Elina Zlotchenko</li><li>Bob Sheehan</li></ul></td>
                </tr>
                <tr>
                  <td>4-5pm</td>
                  <td>330A</td>
                  <td>SIS13: Six Steps to Working with Partners to Advance State DOT CAV Programs</td>
                  <td><ul><li>J.D. Schneeberger</li></ul></td>
                </tr>

                <tr class="table-primary">
                  <th scope="row" colspan="4" class="day-header">Wednesday, June 10</th>
                </tr>
                <tr>
                  <td>8:30-10am</td>
                  <td>Ballroom A</td>
                  <td>Plenary Session: Transforming Transportation: 35 Years of ITS - Connecting the Past and Future</td>
                  <td><ul><li>Seval Oz</li><li>Sean McMaster</li></ul></td>
                </tr>
                <tr>
                  <td>10:30-11:30am</td>
                  <td>330A</td>
                  <td>SIS22: Data Exchange and its Role in the Larger Digital Infrastructure System</td>
                  <td><ul><li>John Corbin</li></ul></td>
                </tr>
                <tr>
                  <td>10:30-11:30am</td>
                  <td>321</td>
                  <td>SIS69: Beyond Connectivity: Bridging the Divide Between Day One V2X and Cooperative Driving Automation</td>
                  <td><ul><li>Sudhakar Nallamothu</li><li>Pavle Bujanovic</li><li>Ahmad Nasser</li></ul></td>
                </tr>
                <tr>
                  <td>10:30-12pm</td>
                  <td>330B</td>
                  <td>AI Benchmarking for Transportation Workshop: Moving from Strategy to Readiness</td>
                  <td><ul><li>Lisa Randall</li><li>Bob Sheehan</li></ul></td>
                </tr>
                <tr>
                  <td>1-2pm</td>
                  <td>321</td>
                  <td>SIS42: Breaking Borders: Accelerating Innovation Through Collaboration</td>
                  <td><ul><li>John Corbin</li></ul></td>
                </tr>
                <tr>
                  <td>4-5pm</td>
                  <td>Theater 1, Booth #1076, Exhibit Hall Floor</td>
                  <td>SIS36: Digitally Testing Tomorrow's Mobility: From Virtual Roads to Real Results</td>
                  <td><ul><li>Danielle Chou</li></ul></td>
                </tr>

                <tr class="table-primary">
                  <th scope="row" colspan="4" class="day-header">Thursday, June 11</th>
                </tr>
                <tr>
                  <td>10:30-11:30am</td>
                  <td>330A</td>
                  <td>SIS55: Beyond Line of Sight – Harmonizing Connectivity and Automation in Autonomous Freight</td>
                  <td><ul><li>Hyungjun Park</li></ul></td>
                </tr>
                <tr>
                  <td>10:30-12pm</td>
                  <td>330B</td>
                  <td>Lessons Learned from SMART Program Grantees</td>
                  <td><ul><li>Stan Caldwell</li></ul></td>
                </tr>
                <tr>
                  <td>1-2pm</td>
                  <td>330A</td>
                  <td>SIS70: Bridging the Gap: USDOT Resources for Trustworthy AI Implementations</td>
                  <td><ul><li>Lisa Randall</li><li>Bob Sheehan</li></ul></td>
                </tr>
                <tr>
                  <td>1-3:30pm</td>
                  <td>330B</td>
                  <td>Connectivity: The Path Forward</td>
                  <td><ul><li>Brian Cronin</li></ul></td>
                </tr>
                <tr>
                  <td>2:30-3:30PM</td>
                  <td>310A</td>
                  <td>SIS61: Empowering Interoperable V2X Deployments: Open-Source Tools for Scalable, Standards-Compliant Connected Transportation</td>
                  <td><ul><li>Marisa Migliore</li></ul></td>
                </tr>
                <tr>
                  <td>2:30-3:30PM</td>
                  <td>330A</td>
                  <td>SIS72: Unified Corridors, Diverse Capabilities: Practical Strategies for Interstate Data Exchange</td>
                  <td><ul><li>Bob Sheehan</li></ul></td>
                </tr>

                <tr class="table-primary">
                  <th scope="row" colspan="4" class="day-header">Friday, June 12</th>
                </tr>
                <tr>
                  <td>1-2pm</td>
                  <td>310A</td>
                  <td>SIS63: A Digital Seatbelt: Interoperable V2X Traveler Information Messages</td>
                  <td><ul><li>Justin Anderson</li></ul></td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="booth-info mb-5 p-4 bg-light rounded-4 border border-2">
          <h3>Visit the ITS JPO Booth</h3>
          <p class="mb-3">
            While you are at the conference, be sure to stop by the <strong>ITS JPO booth (#4031)</strong> in the exhibit hall. ITS JPO program managers will be on hand to discuss current initiatives, especially
            those related to AI and V2X technology. Keep an eye on our social media for announcements regarding the hours when certain staff will be available!
          </p>
          <a
            href="https://www.itsamericaevents.com/expo/en-us/exhibitor-list/exhibitor-details.us%20department%20of%20transportation%20usdot.org-24c8ad9b-6cae-4e15-b39b-775ba369e9ae.html#/"
            class="btn btn-primary btn-lg"
            target="_blank"
            rel="noopener noreferrer"
          >
            Dive Deeper into ITSA 2026
          </a>
        </section>
      </div>
    </section>

    <style>
      .gap-4{
        gap: 1.5rem;
      }
      .text-yellow {
        color: var(--bs-yellow);
        font-weight: 600;
      }
      .gradent-bg {
        background: linear-gradient(0deg, #3b5d86 0%, #10162f 100%);
        color: white;
      }
      .gradent-bg h3 {
        color: white;
        text-transform: none;
        font-size: 2rem;
        margin-bottom: 1.5rem;
        padding: 0;
      }
      .gradent-bg h4 {
        color: var(--bs-yellow);
        font-size: 1.5rem;
        margin-bottom: 1rem;
        text-wrap: balance;
        padding: 0;
      }
      .booth-id {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
      }

      .gradent-bg td {
        color: white;
        text-align: center;
        padding: 0.5rem;
      }

      .gradent-bg tr{
        border-top: 1px solid var(--bs-yellow);
      }

      .gradent-bg table tr:first-child {
          border-top: none;
        }


      p {
        text-wrap: pretty;
      }

      section {
        margin: 0;
        padding: 0;
      }

      .content-card {
        border: 1px solid #e0e0e0;
      }

      .featured-speakers {
        list-style: none;
        padding-left: 0;
      }

      .featured-speakers li {
        padding: 0.75rem 0;
        border-bottom: 1px solid #e9ecef;
        line-height: 1.6;
      }

      .featured-speakers li:last-child {
        border-bottom: none;
      }

      .booth-info {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      }

      /* Schedule Table Styles */

      @media (max-width: 650px) {
        .responsive-table {
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
      }

      .schedule-table {
        font-size: 0.95rem;
        min-width: 650px;
      }

      .schedule-table thead th {
        background-color: #072e55;
        color: white;
        font-weight: 600;
        border: 1px solid #072e55;
        padding: 1rem 0.75rem;
        text-align: left;
        vertical-align: middle;
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .schedule-table tbody td,
      .schedule-table tbody th {
        padding: 0.75rem;
        vertical-align: top;
        line-height: 1.5;
        text-align: left;
        border: 1px solid #dee2e6;
      }

      .schedule-table td ul {
        margin: 0;
        padding-left: 1.25rem;
        list-style-type: disc;
      }

      .schedule-table td ul li {
        margin-bottom: 0.25rem;
      }

      .schedule-table td ul li:last-child {
        margin-bottom: 0;
      }

      .day-header {
        background-color: #3171b4 !important;
        color: white !important;
        font-weight: 700;
        font-size: 1.1rem;
        padding: 0.25rem 0.75rem !important;
        text-align: left;
        position: sticky;
        top: 50px; /* Height of the header row */
        z-index: 11;
      }

      .schedule-table tbody tr:not(.table-primary):hover {
        background-color: #f8f9fa;
      }

      .schedule-table td:nth-child(1) {
        width: 15%;
        white-space: nowrap;
      }

      .schedule-table td:nth-child(2) {
        width: 15%;
      }

      .schedule-table td:nth-child(3) {
        width: 40%;
      }

      .schedule-table td:nth-child(4) {
        width: 30%;
      }
    </style>
  </main></PageLayout
>
