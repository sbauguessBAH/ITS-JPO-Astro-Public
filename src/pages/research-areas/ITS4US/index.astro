---
import base_url from "@/src/lib/base_url";
import Card_WaveBorder from "@/src/components/Card_WaveBorder.astro";
import SeniorTransit from "@/src/assets/images/its4us/SeniorPublicTransit.jpeg";
import Hero from "@/src/assets/images/its4us/ITS4US-Hero.jpg";

import PageLayout from "@/src/layouts/PageLayout.astro";
import logo from "@/src/assets/images/banners/ITS4US_logo_white.png";
---

<style>
  hr {
    margin: 10px 0;
  }
  .blue {
    display: grid;
  }
  .center {
    width: 40%;
  }

  .carousel-indicators {
    position: absolute;
  }
  .carousel-control-prev {
    z-index: 1000;
    left: 0;
    padding: 0;
    margin: 0;
    width: 10%;
  }

  .carousel-control-next {
    z-index: 1000;
    right: 0;
    padding: 0;
    margin: 0;
    width: 10%;
  }
  .carousel-caption {
    background-color: rgba(25, 62, 85, 0.9);
    padding: 10px;
    margin: 0;
    width: 40%;
    left: 10%;
    bottom: 18%;
  }
  .carousel-caption p {
    font-size: smaller;
    margin: 0 0 10px 0;
    padding: 0;
  }
  .btn {
    margin: 0;
  }
  h2 {
    text-wrap: pretty;
  }

  .deployment-sites h2 {
    text-transform: capitalize;
  }

  .deployment-sites {
    background-color: rgb(var(--color-gray));
  }

  .icon-list {
    list-style: none;
    padding-left: 0;
  }

  .icon-list li {
    display: flex;
    align-items: center;
    margin-bottom: 15px;
  }

  .icon-button {
    background-color: rgb(5, 86, 129);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    min-width: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
  }

  .icon-button svg {
    width: 24px;
    height: 24px;
    fill: white;
  }

  @media screen and (max-width: 1400px) {
    .carousel .carousel-item {
      height: 400px;
    }

    .carousel-item img {
      position: absolute;
      object-fit: cover;
      top: 0;
      left: 0;
      min-height: 400px;
    }
  }

  .gray-edge-to-edge {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    transform: translateX(-50%);
    background: #f7f7f7;
    justify-content: center;
    align-items: center;
    display: flex;
  }
  .video-container {
    width: 100%;
  }
  .video-container iframe {
    width: 100%;
    aspect-ratio: 16/9;
  }
</style>

<PageLayout title="ITS4US Home">
  <Fragment slot="banner"> ITS4US</Fragment>
  <main>
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <h2 class="text-center my-4">Providing safe, efficient, and affordable mobility options for everyone:<br />ITS4US – it's transportation for all of us.</h2>
        </div>
        <div class="row">
          <div class="col-12 col-lg-6">
            <p>
              The ITS4US Deployment Program demonstrates how advanced transportation technologies can be integrated, deployed, scaled, and replicated in communities nationwide. Innovative
              transportation technologies used to improve the safety and mobility for all travelers include:
            </p>
            <ul class="icon-list">
              <li>
                <div class="icon-button">
