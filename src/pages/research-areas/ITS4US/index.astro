                      fill-rule="evenodd"
                    >
                    </path>
                  </svg>
                </div>
                <span>Safe intersection crossing applications</span>
              </li>
              <li>
                <div class="icon-button">
                  <svg width="100pt" height="100pt" version="1.1" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <path
