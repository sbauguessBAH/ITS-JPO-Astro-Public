                    >
                    </path>
                    <path d="m53.602 26.898c-2-2-5.1992-2-7.1992 0l3.6016 3.6016z"></path>
                    <path d="m39.199 19.699 3.6016 3.6016c4-4 10.5-4 14.5 0l3.6016-3.6016c-6.0039-6-15.801-6-21.703 0z"></path>
                    <path d="m64.5 16.102 3.6016-3.6016c-10-10-26.199-10-36.102 0l3.6016 3.6016c7.8984-8 20.898-8 28.898 0z"></path>
                  </svg>
                </div>
                <span>Automated and connected vehicle technologies</span>
              </li>
              <li>
                <div class="icon-button">
                  <svg width="100pt" height="100pt" version="1.1" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="m44.5 15.801 5.625 16.77c1.9258 5.7345 6.4258 10.234 12.16 12.156l16.77 5.625c0.95703 0.32032 1.6016 1.2148 1.6016 2.2266 0 1.0078-0.64453 1.8984-1.6016 2.2227l-16.77 5.625c-5.7344 1.9219-10.234 6.4219-12.16 12.156l-5.625 16.77c-0.32031 0.95703-1.2109 1.6016-2.2227 1.6016-1.0078 0-1.8984-0.64453-2.2227-1.6016l-5.625-16.77c-1.9219-5.7344-6.4219-10.234-12.156-12.156l-16.77-5.625c-0.95703-0.32031-1.6016-1.2148-1.6016-2.2227s0.64453-1.9023 1.6016-2.2266l16.77-5.625c5.7344-1.9219 10.234-6.4219 12.156-12.156l5.625-16.77c0.32031-0.95703 1.2148-1.6016 2.2227-1.6016 1.0078 0 1.9023 0.64453 2.2227 1.6016zm-2.2227 8.1172-3.4023 10.145c-2.3867 7.1289-7.9805 12.723-15.109 15.113l-10.145 3.4023 10.145 3.3984c7.1289 2.3906 12.723 7.9844 15.109 15.113l3.4023 10.145 3.4023-10.145c2.3906-7.1289 7.9844-12.723 15.113-15.113l10.145-3.3984-10.145-3.4023c-7.1289-2.3906-12.723-7.9844-15.113-15.113zm38.254-13.262 1.3555 4.0391c1.3516 4.0391 4.5234 7.2109 8.5664 8.5664l4.0391 1.3555c0.95703 0.32031 1.6016 1.2148 1.6016 2.2227 0 1.0078-0.64453 1.9023-1.6016 2.2227l-4.0391 1.3555c-4.0391 1.3555-7.2109 4.5234-8.5664 8.5664l-1.3555 4.043c-0.32031 0.95312-1.2148 1.5977-2.2227 1.5977-1.0078 0-1.9023-0.64453-2.2227-1.5977l-1.3555-4.043c-1.3555-4.0391-4.5234-7.2109-8.5664-8.5664l-4.043-1.3555c-0.95312-0.32031-1.5977-1.2109-1.5977-2.2227 0-1.0078 0.64453-1.8984 1.5977-2.2227l4.043-1.3555c4.0391-1.3516 7.2109-4.5234 8.5664-8.5664l1.3555-4.0391c0.32031-0.95703 1.2148-1.6016 2.2227-1.6016 1.0078 0 1.8984 0.64453 2.2227 1.6016zm-10.746 16.184c3.7227 1.7969 6.7266 4.8047 8.5234 8.5234 1.793-3.7227 4.8008-6.7266 8.5234-8.5234-3.7266-1.793-6.7305-4.8008-8.5234-8.5234-1.7969 3.7266-4.8047 6.7305-8.5234 8.5234z"
