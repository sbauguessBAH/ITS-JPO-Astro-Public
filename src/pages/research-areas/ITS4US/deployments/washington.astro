---
import { Image } from "astro:assets";
import base_url from "@/src/lib/base_url";
import Takashi from "@/src/assets/images/its4us/Takashi.png";
import Map from "@/src/assets/images/its4us/UWMap.png";

import PageLayout from "@/src/layouts/PageLayout.astro";
import logo from "@/src/assets/images/banners/ITS4US_logo_white.png";
import tdeiLogo from "@/src/assets/images/its4us/TDEI-page-logo.png";
import navImage1 from "@/src/assets/images/its4us/TDEI/TDEI-link.png";
import navImage2 from "@/src/assets/images/its4us/DataHub-link.png";
import navImage3 from "@/src/assets/images/its4us/CodeHub-link.png";
import tdeiInfographic from "@/src/assets/images/its4us/TDEI-infographic.png";
import "@/src/styles/deployments.css";
---

<PageLayout title="University of Washington">
  <Fragment slot="banner"> ITS4US</Fragment>

  <main>
    <section class="gray-edge-to-edge">
      <div class="page-content px-xs-4 px-sm-4 px-md-4 px-lg-4 container-xl ">
        <h2>Transportation Data Exchange Initiative</h2>
        <div class="wave-banner-container shadow">
          <div class="p-3">
            <h3 class="text-center purple-text">Improving travel experiences through open transportation data exchange</h3>
            <div class="d-flex flex-md-row flex-column align-items-center gap-3">
              <p class="pb-5 px-3">
                The <span>University of Washington's Transportation Data Exchange Initiative (TDEI)</span> is improving the quality, efficiency and interoperability of transportation services by standardizing
                how transportation data is structured and shared. This approach is being used in <span>Washington, Oregon, and Maryland</span>.
              </p>
              <Image src={tdeiLogo} alt="TDEI Logo" class="page-logo img-fluid px-3" height={230} />
            </div>
          </div>
          <div class="wave-banner purple-wave"></div>
        </div>
      </div>
    </section>

    <section class="container-xl">
      <h2 class="m-0 pb-0">How it Works</h2>
      
      <figure class="figure text-center infographic">
        <a href="#tdeiModal" class="d-inline-block">
          <Image
            src={tdeiInfographic}
            alt="Transportation Data Exchange Initiative Infographic"
            class="figure-img img-fluid w-100"
            width={2000}
          />
        </a>
        <figcaption class="figure-caption text-center">Click to view larger</figcaption>
      </figure>
      
    </section>

    <h2 class="">Features and Benefits</h2>
    <ul class="icon-list">
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
          </svg>
        </div>
        <span><b>Enhance Data Standards</b> — Include information relevant to all travelers and transit stakeholders.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
          </svg>
        </div>
        <span><b>Provide Tools and Data Infrastructure</b> — Reduces barriers for data stewards to collect, vet, maintain and use traveler-centric transportation data at scale.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg width="100pt" height="100pt" version="1.1" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
 <path d="m21.551 28.168-2.4922 27.402c3.6953 2.9062 7.043 6.2305 9.9805 9.9023 2.8203 3.2148 6.332 7.2148 11.043 11.93h-0.003906c1.3281 1.2539 3.4062 1.2539 4.7305 0 1.293-1.3008 1.3008-3.3984 0.011718-4.7031l-0.023437-0.015625-7.0703-7.0781v-0.003907c-0.32031-0.30859-0.50391-0.73828-0.50781-1.1836-0.003906-0.44922 0.17188-0.87891 0.48828-1.1953 0.31641-0.3125 0.74609-0.49219 1.1914-0.48828 0.44922 0.003906 0.875 0.1875 1.1836 0.51172l10.613 10.633h0.003907c1.3125 1.2656 3.3945 1.2656 4.7109 0 0.625-0.625 0.97656-1.4727 0.97656-2.3594 0-0.88281-0.35156-1.7344-0.97656-2.3594l-9.4219-9.4375v0.003906c-0.31641-0.3125-0.49609-0.73828-0.5-1.1797-0.003906-0.44531 0.16797-0.87109 0.48047-1.1875 0.64844-0.65625 1.707-0.66406 2.3633-0.019531l11.777 11.793v0.003907c1.3164 1.2734 3.4102 1.2734 4.7266 0 1.2969-1.3008 1.3008-3.3984 0.007812-4.7031l-0.011719-0.007813v-0.011719l-10.605-10.617 0.003907 0.003906c-0.63281-0.65625-0.625-1.6953 0.019531-2.3359 0.64453-0.64453 1.6836-0.65234 2.3359-0.023438l11.781 11.793v0.003906c0.74609 0.72266 1.7891 1.0625 2.8203 0.92188 0.99609-0.11719 1.8828-0.69141 2.3945-1.5508 0.58203-1.1016 0.53906-2.4297-0.11328-3.4922-0.17578-0.32031-0.39844-0.61328-0.65625-0.87109l-20.941-20.973c-0.3125-0.3125-0.73828-0.48828-1.1797-0.48828s-0.86719 0.17578-1.1797 0.48828l-7.668 7.668c-1.3906 1.418-3.2969 2.2148-5.2812 2.2148h-0.015625c-3.0312-0.007812-5.7656-1.8398-6.9258-4.6445-1.1602-2.8008-0.52344-6.0273 1.6172-8.1797l6.2617-6.2617c-5.3125-0.36719-10.645-0.33594-15.949 0.097657z"/>
 <path d="m33.602 42.598c0.78125 0.78516 1.8398 1.2305 2.9453 1.2266h0.011719c1.0977 0 2.1523-0.44141 2.9219-1.2266l7.6758-7.6758c1.9531-1.9492 5.1172-1.9492 7.0703 0l20.941 20.965c0.089843 0.089843 0.16797 0.19531 0.25 0.28906v0.003907c1.8438-0.95313 3.6094-2.0469 5.2852-3.2656l-2.1172-23.23c-13.438-0.94922-19.754-3.7773-23.57-5.5-3.7109-1.6484-8.0508-0.85156-10.938 2.0078l-10.48 10.5c-0.78516 0.78125-1.2227 1.8438-1.2148 2.9531 0 1.1055 0.4375 2.168 1.2188 2.9531z"/>
 <path d="m5 58.332h8.9375c0.86719 0.003907 1.5898-0.65234 1.668-1.5156l2.7266-30c0.042969-0.46875-0.11328-0.92969-0.42969-1.2773-0.31641-0.34375-0.76562-0.53906-1.2344-0.53906h-11.668c-0.92188 0-1.668 0.74609-1.668 1.668v30c0 0.44141 0.17578 0.86328 0.48828 1.1758s0.73828 0.48828 1.1797 0.48828z"/>
 <path d="m96.668 56.668v-30c0-0.44141-0.17578-0.86719-0.48828-1.1797s-0.73828-0.48828-1.1797-0.48828h-11.668c-0.46484 0-0.91406 0.19922-1.2266 0.54297-0.31641 0.34375-0.47266 0.80859-0.42969 1.2734l2.7266 30c0.078125 0.86328 0.80078 1.5195 1.6641 1.5156h8.9336c0.44141 0 0.86719-0.17578 1.1797-0.48828s0.48828-0.73438 0.48828-1.1758z"/>
</svg>
        </div>
        <span><b>Private/Public Partnerships</b> — Demonstrates work through pilot data collections.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
        </div>
        <span><b>Updating International Data Standards</b> — OpenSidewalks Schema, GTFS-Flex, and GTFS-Pathways.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
        </div>
        <span><b>Data Governance Groups</b> — Working to update and refine standards to address open exchange in transportation data.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
          </svg>
        </div>
        <span><b>Walkshed Analysis Tool</b> — Quantify and analyze access to/from a point with detailed statistics on accessible community resources, accessibility barriers and other measures.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </div>
        <span><b>AccessMap Multimodal</b> — A trip planner that allows users to express sidewalk preferences and receive suitable paths via mapped infrastructure.</span>
      </li>
    </ul>
    
    <section class="gray-edge-to-edge mt-4">
      <div class="page-content px-xs-4 px-sm-4 px-md-4 px-lg-4 container-xl">
        <h2 class="">Get Involved</h2>

        <div class="row g-3">
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card rounded-3 h-100 p-2">
        <Image src={navImage1} alt="TDEI website link" class="img-fluid rounded mb-2" width={300} />
        <a href="https://tdei.cs.washington.edu/" target="_blank" rel="noopener noreferrer">TDEI Website</a>
        </div>
      </div>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card rounded-3 h-100 p-2">
        <Image src={navImage2} alt="ITS DataHub link" class="img-fluid rounded mb-2" width={300} />
        <a href="https://www.its.dot.gov/data/" target="_blank" rel="noopener noreferrer">Data Hub</a>
        </div>
      </div>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card rounded-3 h-100 p-2">
        <Image src={navImage3} alt="ITS CodeHub link" class="img-fluid rounded mb-2" width={300} />
        <a href="https://www.its.dot.gov/code/" target="_blank" rel="noopener noreferrer">Code Hub</a>
        </div>
      </div>
    </div>
      </div>
    </section>

  {/* Modal for enlarged image */}
  <div id="tdeiModal" class="img-modal">
    <a href="#!" class="img-modal__overlay" aria-label="Close"></a>
    <div class="img-modal__dialog" role="dialog" aria-modal="true" aria-label="Transportation Data Exchange Initiative Infographic">
      <a href="#!" class="img-modal__close" aria-label="Close">&times;</a>
      <Image
        src={tdeiInfographic}
        alt="Transportation Data Exchange Initiative Infographic"
        class="img-fluid w-100"
      />
    </div>
  </div>

  </main>
</PageLayout>

<style>
 figcaption{
  padding: 0;
  margin: 0;
 }
  figure{
    width: 100%;
    display: block;
    position: relative;
    padding: 0;
    margin: 0;
  }

  .infographic{
    padding: 0 1rem;
  }

  .icon-list {
    list-style: none;
    padding-left: 0;
  }

  .icon-list li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 10px;
    padding-left: 0;
  }

  .icon-button {
    background-color: transparent;
    width: 18px;
    height: 18px;
    min-width: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 10px;
    margin-top: 3px;
    flex-shrink: 0;
  }

  .icon-button svg {
    width: 18px;
    height: 18px;
    fill: #614384;
  }


  /* Pure CSS modal */
  .img-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1050;
  }

  .img-modal:target {
    display: flex;
  }

  .img-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .img-modal__dialog {
    position: relative;
    max-width: min(1200px, 90vw);
    max-height: 90vh;
    padding: 0.5rem;
    background: #fff;
    border-radius: 0.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .img-modal__dialog img {
    max-height: 90vh;
    display: block;
  }

  .img-modal__close {
    position: absolute;
    top: 0.35rem;
    right: 0.6rem;
    color: #000;
    font-size: 2rem;
    line-height: 1;
    text-decoration: none;
  }

  .img-modal__close:focus-visible,
  a[href="#tdeiModal"]:focus-visible {
    outline: 2px solid #0d6efd;
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
