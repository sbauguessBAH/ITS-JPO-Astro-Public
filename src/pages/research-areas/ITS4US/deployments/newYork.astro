---
import { Image } from "astro:assets";
import base_url from "@/src/lib/base_url";
import letitia from "@/src/assets/images/its4us/letitia.png";
import Map from "@/src/assets/images/its4us/buffalo-map.png";

import PageLayout from "@/src/layouts/PageLayout.astro";
import logo from "@/src/assets/images/banners/ITS4US_logo_white.png";
import buffaloLogo from "@/src/assets/images/its4us/buffalo-page-logo.png";
import resourceImg1 from "@/src/assets/images/its4us/BAA/BAA-link.png";
import resourceImg2 from "@/src/assets/images/its4us/BAA/Complete-Trip-link.png";
import resourceImg3 from "@/src/assets/images/its4us/DataHub-link.png";
import resourceImg4 from "@/src/assets/images/its4us/CodeHub-link.png";
import baaInfographic from "@/src/assets/images/its4us/BAA-infographic.png";
import "@/src/styles/deployments.css";
---

<PageLayout title="Niagara Frontier Transportation Authority">
  <Fragment slot="banner"> ITS4US</Fragment>
  <main>
<section class="gray-edge-to-edge">
      <div class=" page-content px-xs-4 px-sm-4 px-md-4 px-lg-4 container-xl ">
  <h2 class="">Buffalo All Access</h2>
  <div class="wave-banner-container shadow">
    <div class="p-3">
      <h3 class="text-center blue-text">Your Ride Has Arrived!</h3>
      <div class="d-flex flex-md-row flex-column align-items-center gap-3">
        <p class="pb-5 px-3">The <span>Niagara Frontier Transportation Authority (NFTA)'s</span> Buffalo All Access project demonstrates how innovative technology can improve public transportation access and efficiency in a medical campus setting, making it easier for patients, staff, and visitors to navigate the area safely and efficiently in <span>Buffalo, New York.</span></p>
        <Image src={buffaloLogo} alt="Buffalo All Access Logo" class="page-logo img-fluid px-3" height={230} />
      </div>
    </div>
    <div class="wave-banner blue-wave">
    </div>
  </div>
      </div>
    </section>

    <section class="container-xl">
      <h2 class="m-0 pb-0">How it Works</h2>
      
      <figure class="figure text-center infographic">
        <a href="#baaModal" class="d-inline-block">
          <Image
            src={baaInfographic}
            alt="Buffalo All Access Infographic"
            class="figure-img img-fluid w-100"
            width={2000}
          />
        </a>
        <figcaption class="figure-caption text-center">Click to view larger</figcaption>
      </figure>
      
    </section>

  <h2 class="">Features and Benefits</h2>
  <ul class="icon-list">
    <li>
      <div class="icon-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14z"/>
        </svg>
      </div>
      <span><b>Buffalo All Access Mobile App</b> — Real-time step-by-step navigation and the ability to hail a free on-demand shuttle within the shuttle service area.</span>
    </li>
    <li>
      <div class="icon-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"/>
        </svg>
      </div>
      <span><b>On-Demand Shuttle System</b> — Community Shuttle which provides door-to-door service in the shuttle service area, and the first-of-its-kind All Access Loop: a self-driving shuttle that circulates the area.</span>
    </li>
    <li>
      <div class="icon-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M20 10h-3V8.86c1.72-.45 3-2 3-3.86h-3V4c0-.55-.45-1-1-1H8c-.55 0-1 .45-1 1v1H4c0 1.86 1.28 3.41 3 3.86V10H4c0 1.86 1.28 3.41 3 3.86V15H4c0 1.86 1.28 3.41 3 3.86V20c0 .55.45 1 1 1h8c.55 0 1-.45 1-1v-1.14c1.72-.45 3-2 3-3.86h-3v-1.14c1.72-.45 3-2 3-3.86z"/>
        </svg>
      </div>
      <span><b>Remote Pedestrian Signal Actuation (PEDX)</b> — Used throughout Buffalo and the state to manage intersections and signals.</span>
    </li>
    <li>
      <div class="icon-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/>
        </svg>
      </div>
      <span><b>Wayfinding Technologies</b> — App provides turn-by-turn wayfinding assistance based on your unique needs and abilities, both outdoors and indoors at Visually Impaired Advancement's headquarters and at the Buffalo General Medical Center.</span>
    </li>
    <li>
      <div class="icon-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h5v2h8v-2h5c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 14H3V5h18v12z"/>
        </svg>
      </div>
      <span><b>All Access Kiosks</b> — Two kiosks with the Buffalo All Access App located at the Summer-Best Metro Rail Station and inside Buffalo General Medical Center.</span>
    </li>
  </ul>
  
  <section class="gray-edge-to-edge mt-4">
    <div class="page-content px-xs-4 px-sm-4 px-md-4 px-lg-4 container-xl">
      <h2 class="">Get Involved</h2>

      <div class="row g-3">
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card rounded-3 h-100 p-2">
      <Image src={resourceImg1} alt="Buffalo All Access website link" class="img-fluid rounded mb-2" width={300} />
      <a href="https://bnmc.org/transportation/buffalo-all-access/" target="_blank" rel="noopener noreferrer">Buffalo All Access Website</a>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card rounded-3 h-100 p-2">
      <Image src={resourceImg2} alt="Complete Trip mobile and web applications" class="img-fluid rounded mb-2" width={300} />
      <a href="https://apps.apple.com/us/app/buffalo-all-access/id1668202535" target="_blank" rel="noopener noreferrer">Complete Trip – Apple</a>
      <a href="https://play.google.com/store/apps/details?id=app.etch.ctp&pcampaignid=web_share" target="_blank" rel="noopener noreferrer">Complete Trip – Google Play</a>
      <a href="https://completetrip.etch.app/map" target="_blank" rel="noopener noreferrer">Complete Trip Web App</a>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card rounded-3 h-100 p-2">
      <Image src={resourceImg3} alt="ITS DataHub link" class="img-fluid rounded mb-2" width={300} />
      <a href="https://www.its.dot.gov/data/" target="_blank" rel="noopener noreferrer">Data Hub</a>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-3">
      <div class="card rounded-3 h-100 p-2">
      <Image src={resourceImg4} alt="ITS CodeHub link" class="img-fluid rounded mb-2" width={300} />
      <a href="https://www.its.dot.gov/code/" target="_blank" rel="noopener noreferrer">Code Hub</a>
      </div>
    </div>
  </div>
    </div>
  </section>

  {/* Modal for enlarged image */}
  <div id="baaModal" class="img-modal">
    <a href="#!" class="img-modal__overlay" aria-label="Close"></a>
    <div class="img-modal__dialog" role="dialog" aria-modal="true" aria-label="Buffalo All Access Infographic">
      <a href="#!" class="img-modal__close" aria-label="Close">&times;</a>
      <Image
        src={baaInfographic}
        alt="Buffalo All Access Infographic"
        class="img-fluid w-100"
      />
    </div>
  </div>

  </main> 
</PageLayout>

<style>
 figcaption{
  padding: 0;
  margin: 0;
 }
  figure{
    width: 100%;
    display: block;
    position: relative;
    padding: 0;
    margin: 0;
  }

  .infographic{
    padding: 0 1rem;
  }

  .icon-list {
    list-style: none;
    padding-left: 0;
  }

  .icon-list li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 10px;
    padding-left: 0;
  }

  .icon-button {
    background-color: transparent;
    width: 18px;
    height: 18px;
    min-width: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 10px;
    margin-top: 3px;
    flex-shrink: 0;
  }

  .icon-button svg {
    width: 18px;
    height: 18px;
    fill: #2166b2;
  }


  /* Pure CSS modal */
  .img-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1050;
  }

  .img-modal:target {
    display: flex;
  }

  .img-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .img-modal__dialog {
    position: relative;
    max-width: min(1200px, 90vw);
    max-height: 90vh;
    padding: 0.5rem;
    background: #fff;
    border-radius: 0.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .img-modal__dialog img {
    max-height: 90vh;
    display: block;
  }

  .img-modal__close {
    position: absolute;
    top: 0.35rem;
    right: 0.6rem;
    color: #000;
    font-size: 2rem;
    line-height: 1;
    text-decoration: none;
  }

  .img-modal__close:focus-visible,
  a[href="#baaModal"]:focus-visible {
    outline: 2px solid #0d6efd;
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
