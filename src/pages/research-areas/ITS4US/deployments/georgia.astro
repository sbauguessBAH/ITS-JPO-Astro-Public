---
import { Image } from "astro:assets";
import base_url from "@/src/lib/base_url";
import Andre from "@/src/assets/images/its4us/andre.png";
import Map from "@/src/assets/images/its4us/ST-CTN-map.png";
import PageLayout from "@/src/layouts/PageLayout.astro";
import logo from "@/src/assets/images/banners/ITS4US_logo_white.png";
---

<style>
  hr {
    margin: 10px 0;
  }
  .blue {
    display: grid;
  }

  figure {
    margin: auto;
    width: 30%;
    float: right;
    margin: 10px;
  }
  figcaption {
    color: #333;
    font-style: italic;
    font-size: small;
    padding: 10px;
  }

  figcaption p {
    padding: 0;
    margin: 0;
    font-size: small;
  }
  iframe {
    display: block;
    margin: auto;
    margin-bottom: 20px;
  }

  .wave-banner-container {
    position: relative;
    background-color: rgb(var(--color-gray));
    padding: 2rem;
    margin-bottom: 2rem;
    border-radius: 0.5rem;
    box-shadow: 0 5px 8px rgba(0, 0, 0, 0.3);
  }

  .wave-banner {
     position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 100px;
    width: 100%;
    pointer-events: none;
    z-index: -1;
    display: flex;
    align-items: flex-end;
    padding: 0 1rem 0.75rem;
    border-radius: 15px;
  }

  .wave-banner-container p {
    font-size: 1.5rem; 
    line-height: 1.5rem;
  }

  .wave-banner-container p span {
    font-weight: 700;
    color: rgb(var(--color-primary));
  }

  .wave-banner-container h3 {
    font-size: 2rem;
    line-height: 2.5rem;
    margin-bottom: 1rem;
    text-transform: none;
    color: rgb(var(--color-primary));
  }

  .wave-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    clip-path: polygon(100% 100%, 0% 100%, 0% 24.73%, 6.67% 24.25%, 13.33% 22.84%, 20% 20.64%, 26.67% 17.82%, 33.33% 14.62%, 40% 11.33%, 46.67% 8.21%, 53.33% 5.54%, 60% 3.55%, 66.67% 2.4%, 73.33% 2.19%, 80% 2.94%, 86.67% 4.59%, 93.33% 7%, 100% 9.95%);
    background: #f7a321;
  }
  
  .wave-banner::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #e57829;
    clip-path: polygon(100% 100%, 0% 100%, 0% 9.15%, 6.67% 5.24%, 13.33% 2.14%, 20% .51%, 26.67% .68%, 33.33% 2.61%, 40% 5.91%, 46.67% 9.89%, 53.33% 13.72%, 60% 16.59%, 66.67% 17.91%, 73.33% 17.41%, 80% 15.18%, 86.67% 11.7%, 93.33% 7.69%, 100% 3.98%);
  }

  .link-card {
    
  }


</style>
<PageLayout title="Georgia Department of Transportation">

  <Fragment slot="banner"> <img 
    alt="ITS4US Logo" 
    src={logo.src} 
    style="max-height: 60px; clear: none" 
  /> | ITS4US</Fragment>
  <main>

  <h2 class="sideways">Georgia Mobility and Access Planner</h2>
  <div class="wave-banner-container shadow">
    <div class="p-3">
      <h3 class="sideways text-center">Get to care reliably and affordably.</h3>
      <div class="d-flex">
        <p class="pb-5">The <span>Georgia Department of Transportation (GDOT)'s</span> Mobility and Access Planner is an innovative solution that utilizes advanced transportation technologies to improve mobility access for Georgia residents.</p>
        <img src="" alt="GDOT logo"/>
      </div>
    </div>
    <div class="wave-banner">
    </div>
  </div>
  <h2 class="sideways">How It Works</h2>
  <img src="" alt="A road map depicting 6 phases. Phase 1: , Phase 2: , Phase 3: , Phase 4: , Phase 5: , Phase 6:." />
  <h2 class="sideways">Featured Benefits</h2>
  <ul>
    <li><b>Integrated scheduling</b> — Book transport during medical appointment setup.</li>
    <li><b>Multi-channel booking</b> — App, web, or phone.</li>
    <li><b>Partner fleets</b> — Extra capacity when needed.</li>
    <li><b>Indoor wayfinding</b> — Find the right clinic quickly.</li>
    <li><b>Real-time updates</b> — Track vehicle arrival and ETA.</li>
    <li><b>Low fares</b> — Affordable pricing to reduce no-shows</li>
  </ul>
  <h2 class="sideways">Get Involved</h2>
  <div class="d-flex full-width justify-content-around">
    <div class="link-card map">
      <a href="https://www.dot.ga.gov/">Georgia Mobility Planner Website</a>
    </div>
    <div class="link-card location">
      <a href="https://www.dot.ga.gov/">ST-CTN</a>
    </div>
    <div class="link-card arrow">
      <a href="https://www.dot.ga.gov/">Georgia Mobility Documentation</a>
    </div>
  </div>
  </main>
</PageLayout>
