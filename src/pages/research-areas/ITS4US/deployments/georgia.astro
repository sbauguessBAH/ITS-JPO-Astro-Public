---
import { Image } from "astro:assets";
import base_url from "@/src/lib/base_url";
import Andre from "@/src/assets/images/its4us/andre.png";
import Map from "@/src/assets/images/its4us/ST-CTN-map.png";
import PageLayout from "@/src/layouts/PageLayout.astro";
import logo from "@/src/assets/images/banners/ITS4US_logo_white.png";
import georgiaLogo from "@/src/assets/images/its4us/Georgia-page-logo.png";
import cardImage1 from "@/src/assets/images/its4us/GMAP/GMAP-link.png";
import cardImage2 from "@/src/assets/images/its4us/GMAP/GMAP-app-link.png";
import cardImage3 from "@/src/assets/images/its4us/DataHub-link.png";
import cardImage4 from "@/src/assets/images/its4us/CodeHub-link.png";
import gmapInfographic from "@/src/assets/images/its4us/GMAP-infographic.png";
import "@/src/styles/deployments.css";
---

<PageLayout title="Georgia Department of Transportation">
  <Fragment slot="banner"> <img alt="ITS4US Logo" src={logo.src} style="max-height: 60px; clear: none" /> | ITS4US</Fragment>
  <main>
    <section class="gray-edge-to-edge">
      <div class="page-content px-xs-4 px-sm-4 px-md-4 px-lg-4 container-xl">
        <h2>Georgia Mobility and Access Planner</h2>
        <div class="wave-banner-container shadow">
          <div class="p-3">
            <h3 class="text-center orange-text">Your journey, your path – mobility through greater access</h3>
            <div class="d-flex flex-md-row flex-column align-items-center gap-3">
              <p class="pb-5 px-3">
                The <span>Georgia Department of Transportation (GDOT)'s</span> Georgia Mobility and Access Planner (G-MAP) is an integrated mobile trip planning application with indoor and outdoor pedestrian
                navigation features in <span>Gwinnett County, Georgia</span>.
              </p>
              <Image src={georgiaLogo} alt="Georgia Department of Transportation Logo" class="page-logo img-fluid px-3" height={230} />
            </div>
          </div>
          <div class="wave-banner orange-wave"></div>
        </div>
      </div>
    </section>
    <section class="container-xl">
      <h2 class="m-0 pb-0">How it Works</h2>

      <figure class="figure text-center infographic">
        <a href="#hcModal" class="d-inline-block">
          <Image src={gmapInfographic} alt="Georgia Mobility and Access Planner Infographic" class="figure-img img-fluid w-100" width={2000} />
        </a>
        <figcaption class="figure-caption text-center">Click to view larger</figcaption>
      </figure>
    </section>
    <h2>Features and Benefits</h2>
    <ul class="icon-list">
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"></path>
          </svg>
        </div>
        <span><b>Customized Trip Preferences</b> — Pre-trip planning based on needs and preferences.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path
              d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z"
            >
            </path>
          </svg>
        </div>
        <span><b>Transit Signal Priority</b> — Notification of accommodations and needs for boarding.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"></path>
          </svg>
        </div>
        <span><b>Turn-by-turn Directions</b> — Provides support services if needed.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg width="100pt" height="100pt" version="1.1" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <path
              d="m64.062 35.938v-29.688c0-0.86328-0.69922-1.5625-1.5625-1.5625h-25c-0.86327 0-1.5625 0.69922-1.5625 1.5625v29.688h-29.688c-0.86328 0-1.5625 0.69922-1.5626 1.5625v25c0 0.86328 0.69922 1.5625 1.5625 1.5625h29.688v29.688c0 0.86327 0.69922 1.5625 1.5625 1.5625h25c0.86328 0 1.5625-0.69922 1.5625-1.5625v-29.688h29.688c0.86328 0 1.5625-0.69922 1.5625-1.5625v-25c0-0.86328-0.69922-1.5625-1.5625-1.5625zm-12.5 48.438v-6.25c0-0.86328-0.69922-1.5625-1.5625-1.5625s-1.5625 0.69922-1.5625 1.5625v6.25c0 0.86328 0.69922 1.5625 1.5625 1.5625s1.5625-0.69922 1.5625-1.5625zm0-15.625v-6.25c0-0.86328-0.69922-1.5625-1.5625-1.5625s-1.5625 0.69922-1.5625 1.5625v6.25c0 0.86328 0.69922 1.5625 1.5625 1.5625s1.5625-0.69922 1.5625-1.5625zm-29.688-20.312h-6.25c-0.86328 0-1.5625 0.69922-1.5625 1.5625s0.69922 1.5625 1.5625 1.5625h6.25c0.86328 0 1.5625-0.69922 1.5625-1.5625s-0.69922-1.5625-1.5625-1.5625zm15.625 0h-6.25c-0.86328 0-1.5625 0.69922-1.5625 1.5625s0.69922 1.5625 1.5625 1.5625h6.25c0.86328 0 1.5625-0.69922 1.5625-1.5625s-0.69922-1.5625-1.5625-1.5625zm31.25 0h-6.25c-0.86328 0-1.5625 0.69922-1.5625 1.5625s0.69922 1.5625 1.5625 1.5625h6.25c0.86328 0 1.5625-0.69922 1.5625-1.5625s-0.69922-1.5625-1.5625-1.5625zm15.625 0h-6.25c-0.86328 0-1.5625 0.69922-1.5625 1.5625s0.69922 1.5625 1.5625 1.5625h6.25c0.86328 0 1.5625-0.69922 1.5625-1.5625s-0.69922-1.5625-1.5625-1.5625zm-32.812-10.938v-6.25c0-0.86328-0.69922-1.5625-1.5625-1.5625s-1.5625 0.69922-1.5625 1.5625v6.25c0 0.86328 0.69922 1.5625 1.5625 1.5625s1.5625-0.69922 1.5625-1.5625zm0-15.625v-6.25c0-0.86328-0.69922-1.5625-1.5625-1.5625s-1.5625 0.69922-1.5625 1.5625v6.25c0 0.86328 0.69922 1.5625 1.5625 1.5625s1.5625-0.69922 1.5625-1.5625z"
              fill-rule="evenodd"
            >
            </path>
          </svg>
        </div>
        <span><b>Intersection Crossing</b> — Interaction with signal controller and provides additional crossing time if needed.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path
              d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-12.5c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 5.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"
            >
            </path>
          </svg>
        </div>
        <span><b>CV Broadcast Message</b> — Provides communication to enabled connected vehicles to make them aware of the traveler's presence.</span>
      </li>
      <li>
        <div class="icon-button">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path>
          </svg>
        </div>
        <span>
          <b>Outdoor/Indoor Navigation</b> — Provides the traveler with hands-free indoor (at two county facilities) and outdoor navigation via G-MAP and/or wearables and accessible channels (haptic, voice,
          text).
        </span>
      </li>
    </ul>

    <section class="gray-edge-to-edge mt-4">
      <div class="page-content px-xs-4 px-sm-4 px-md-4 px-lg-4 container-xl">
        <h2>Get Involved</h2>

        <div class="row g-3">
          <div class="col-12 col-md-6 col-lg-3">
            <div class="card rounded-3 h-100 p-2">
              <Image src={cardImage1} alt="G-MAP website link" class="img-fluid rounded mb-2" width={300} />
              <a href="https://georgia-map.com/" target="_blank" rel="noopener noreferrer">G-MAP Website</a>
            </div>
          </div>
          <div class="col-12 col-md-6 col-lg-3">
            <div class="card rounded-3 h-100 p-2">
              <Image src={cardImage2} alt="G-MAP mobile application download links" class="img-fluid rounded mb-2" width={300} />
              <a href="https://apps.apple.com/us/app/g-map/id6446321525" target="_blank" rel="noopener noreferrer">G-MAP Apple</a>
              <a href="https://play.google.com/store/apps/details?id=com.ibigroup.mobile.otp.its4us.android&pcampaignid=web_share" target="_blank" rel="noopener noreferrer">G-MAP Google Play</a>
            </div>
          </div>
          <div class="col-12 col-md-6 col-lg-3">
            <div class="card rounded-3 h-100 p-2">
              <Image src={cardImage3} alt="ITS DataHub link" class="img-fluid rounded mb-2" width={300} />
              <a href="https://www.its.dot.gov/data/" target="_blank" rel="noopener noreferrer">Data Hub</a>
            </div>
          </div>
          <div class="col-12 col-md-6 col-lg-3">
            <div class="card rounded-3 h-100 p-2">
              <Image src={cardImage4} alt="ITS CodeHub link" class="img-fluid rounded mb-2" width={300} />
              <a href="https://www.its.dot.gov/code/" target="_blank" rel="noopener noreferrer">Code Hub</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Modal for enlarged image */}
    <div id="hcModal" class="img-modal">
      <a href="#!" class="img-modal__overlay" aria-label="Close"></a>
      <div class="img-modal__dialog" role="dialog" aria-modal="true" aria-label="Georgia Mobility and Access Planner Infographic">
        <a href="#!" class="img-modal__close" aria-label="Close">&times;</a>
        <Image src={gmapInfographic} alt="Georgia Mobility and Access Planner Infographic" class="img-fluid w-100" />
      </div>
    </div>
  </main>
</PageLayout>

<style>
  figcaption {
    padding: 0;
    margin: 0;
  }
  figure {
    width: 100%;
    display: block;
    position: relative;
    padding: 0;
    margin: 0;
  }

  .infographic {
    padding: 0 1rem;
  }

  .icon-list {
    list-style: none;
    padding-left: 0;
  }

  .icon-list li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 10px;
    padding-left: 0;
  }

  .icon-button {
    background-color: transparent;
    width: 18px;
    height: 18px;
    min-width: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 10px;
    margin-top: 3px;
    flex-shrink: 0;
  }

  .icon-button svg {
    width: 18px;
    height: 18px;
    fill: #e57829;
  }

  /* Pure CSS modal */
  .img-modal {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1050;
  }

  .img-modal:target {
    display: flex;
  }

  .img-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .img-modal__dialog {
    position: relative;
    max-width: min(1200px, 90vw);
    max-height: 90vh;
    padding: 0.5rem;
    background: #fff;
    border-radius: 0.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .img-modal__dialog img {
    max-height: 90vh;
    display: block;
  }

  .img-modal__close {
    position: absolute;
    top: 0.35rem;
    right: 0.6rem;
    color: #000;
    font-size: 2rem;
    line-height: 1;
    text-decoration: none;
  }

  .img-modal__close:focus-visible,
  a[href="#hcModal"]:focus-visible {
    outline: 2px solid #0d6efd;
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
