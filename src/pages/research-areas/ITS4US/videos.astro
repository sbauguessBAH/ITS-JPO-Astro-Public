---
import { Image } from "astro:assets";
import base_url from "@/src/lib/base_url";
import Photo1 from "@/src/assets/images/its4us/accessible-signal.jpeg";
import ProgramPhase from "@/src/assets/images/its4us/ITS4US-Program-Phases3.png";
import TravelerMap from "@/src/assets/images/its4us/TravelerMap.jpeg";

import PageLayout from "@/src/layouts/PageLayout.astro";
import logo from "@/src/assets/images/banners/ITS4US_logo_white.png";
import healthConnectorLogo from "@/src/assets/images/its4us/Health-Connector-page-logo.png";
import georgiaLogo from "@/src/assets/images/its4us/Georgia-page-logo.png";
import buffaloLogo from "@/src/assets/images/its4us/buffalo-page-logo.png";
import tdeiLogo from "@/src/assets/images/its4us/TDEI-page-logo.png";
---

<style>
  hr {
    margin: 10px 0;
  }
  .blue {
    display: flex;
  }
  .imgae-container {
    width: 33%;
  }

  /* Video iframe container */
  .video-container {
    width: 85%;
    margin: 0 auto;
  }

  /* Video Cards Grid */
  .video-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .video-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .video-cards-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .video-card {
    position: relative;
    background: white;
    border-radius: 0.75rem;
    box-shadow: 0 5px 8px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
  }

  .video-card-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    min-height: 120px;
    display: flex;
    gap: 0;
    align-items: center;
    background-color: white;
    margin: 0 0 1rem 0;
    padding: 0 0 1rem 0;
    justify-content: space-between;
  }

  .card-header h3 {
    margin-bottom: 0;
    padding: 0;
  }

  .card-divider {
    margin: 1rem 0;
    border: 0;
    border-top: 2px solid #e5e7eb;
  }

  .card-logo {
    float: right;
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin: 0 0 1rem 1rem;
  }

  .video-card h3 {
    font-size: 1.25rem;
    line-height: 1.1;
    margin-bottom: 0;
    color: rgb(var(--color-primary));
    text-transform: none;
  }

  .video-links {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
  }

  .video-links li {
    margin-bottom: 0.75rem;
  }

  .video-links .coming-soon {
    color: #666;
    font-style: italic;
    display: block;
    padding: 0.25rem 0;
  }

  /* Card Wave Styles */
  .card-wave {
    position: relative;
    height: 60px;
    width: 100%;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
  }

  .card-wave::before,
  .card-wave::after {
    content: "";
    position: absolute;
    inset: 0;
  }

  .card-wave::before {
    z-index: 1;
    clip-path: polygon(
      100% 100%,
      0% 100%,
      0% 24.73%,
      6.67% 24.25%,
      13.33% 22.84%,
      20% 20.64%,
      26.67% 17.82%,
      33.33% 14.62%,
      40% 11.33%,
      46.67% 8.21%,
      53.33% 5.54%,
      60% 3.55%,
      66.67% 2.4%,
      73.33% 2.19%,
      80% 2.94%,
      86.67% 4.59%,
      93.33% 7%,
      100% 9.95%
    );
  }

  .card-wave::after {
    z-index: 0;
    clip-path: polygon(
      100% 100%,
      0% 100%,
      0% 9.15%,
      6.67% 5.24%,
      13.33% 2.14%,
      20% 0.51%,
      26.67% 0.68%,
      33.33% 2.61%,
      40% 5.91%,
      46.67% 9.89%,
      53.33% 13.72%,
      60% 16.59%,
      66.67% 17.91%,
      73.33% 17.41%,
      80% 15.18%,
      86.67% 11.7%,
      93.33% 7.69%,
      100% 3.98%
    );
  }

  /* Green wave (Health Connector) */
  .card-wave.green-wave::before {
    background: #28b24b;
  }

  .card-wave.green-wave::after {
    background: #b9be33;
  }

  /* Orange wave (Georgia) */
  .card-wave.orange-wave::before {
    background: #f7a321;
  }

  .card-wave.orange-wave::after {
    background: #e57829;
  }

  /* Blue wave (Buffalo) */
  .card-wave.blue-wave::before {
    background: #2166b2;
  }

  .card-wave.blue-wave::after {
    background: #0084c3;
  }

  /* Purple wave (TDEI) */
  .card-wave.purple-wave::before {
    background: #614384;
  }

  .card-wave.purple-wave::after {
    background: #8a82a0;
  }

  .gray-edge-to-edge {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    transform: translateX(-50%);
    background: #f7f7f7;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 2rem;
    margin-bottom: 0;
    margin-top: 2rem;
    box-sizing: border-box;
  }
</style>

<PageLayout title="Program Overview">
  <Fragment slot="banner"> ITS4US</Fragment>
  <main>
    <h2 class="py-3">ITS4US Video Library</h2>

    <p>
      Except for the statutes and regulations cited, the contents of these videos do not have the force and effect of law and are not meant to bind the States or the public in any way. These videos
      are intended only to provide information regarding existing requirements under the law or agency policies.
    </p>

    <p>
      The U.S. Government does not endorse products or manufacturers. Trademarks or manufacturers’ names appear in this video only because they are considered essential to the objective of the
      presentation. They are included for informational purposes only and are not intended to reflect a preference, approval, or endorsement of any one product or entity.
    </p>

    <div class="video-container">
      <div class="w-100 ratio ratio-16x9">
        <iframe
          class="rounded-4"
          src="https://www.youtube.com/embed/VgQDCelHSEs"
          title="ITS4US Deployment Program Overview"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
        >
        </iframe>
      </div>
    </div>
    <section class="gray-edge-to-edge">
      <div class="container">
        <h2 class="py-4 mt-5">Deployment Videos</h2>
        <div class="video-cards-grid">
          <!-- Health Connector Card -->
          <div class="video-card">
            <div class="video-card-content">
              <div class="card-header">
                <h3>Health Connector Videos</h3>
                <Image src={healthConnectorLogo} alt="Health Connector Logo" class="card-logo" width={180} />

              </div>

              <ul class="video-links">
                <li><a href="https://youtu.be/xRbNLpA6IQs" target="_blank" rel="noopener noreferrer">Overview of Health Connector</a></li>
                <li><a href="https://youtu.be/VBedCBGP9Bo" target="_blank" rel="noopener noreferrer">Health Connector Information for Travelers</a></li>
                <li><a href="https://youtu.be/QzA1avpZdhg" target="_blank" rel="noopener noreferrer">Health Connector Information for Partners</a></li>
                <li><a href="https://youtu.be/fgmPfst9pjw" target="_blank" rel="noopener noreferrer">Registration Walkthrough</a></li>
              </ul>
            </div>
            <div class="card-wave green-wave"></div>
          </div>

          <!-- Georgia Mobility Card -->
          <div class="video-card">
            <div class="video-card-content">
              <div class="card-header">
                <h3>Georgia Mobility and Access Planner Videos</h3>
               <Image src={georgiaLogo} alt="Georgia Mobility and Access Planner Logo" class="card-logo" width={180} />
              </div>

              <ul class="video-links">
                <li><a href="https://vimeo.com/863329944" target="_blank" rel="noopener noreferrer">Overview of G-MAP</a></li>
                <li><a href="https://vimeo.com/997811747" target="_blank" rel="noopener noreferrer">User Testimonial for G-MAP</a></li>
              </ul>
            </div>
            <div class="card-wave orange-wave"></div>
          </div>

          <!-- Buffalo All Access Card -->
          <div class="video-card">
            <div class="video-card-content">
              <div class="card-header">
                <h3>Buffalo All Access Videos</h3>
                <Image src={buffaloLogo} alt="Buffalo All Access Logo" class="card-logo" width={180} />

              </div>

              <ul class="video-links">
                <li><a href="https://www.youtube.com/watch?v=bqaCbW7iXFg" target="_blank" rel="noopener noreferrer">Overview of Buffalo All Access</a></li>
              </ul>
            </div>
            <div class="card-wave blue-wave"></div>
          </div>

          <!-- TDEI Card -->
          <div class="video-card">
            <div class="video-card-content">
              <div class="card-header">
                <h3>Transportation Data Exchange Initiative Videos</h3>
               <Image src={tdeiLogo} alt="Transportation Data Exchange Initiative Logo" class="card-logo" width={180} />

              </div>

              <ul class="video-links">
                <li><a href="https://youtu.be/fA2GDSSEtzA" target="_blank" rel="noopener noreferrer">Overview of TDEI</a></li>
                <li><a href="https://youtu.be/506XrN7WhsU" target="_blank" rel="noopener noreferrer">Full Overview of TDEI</a></li>
              </ul>
            </div>
            <div class="card-wave purple-wave"></div>
          </div>
        </div>
      </div>
    </section>
  </main>
</PageLayout>
