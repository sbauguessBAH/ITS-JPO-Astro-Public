---
import banner from "@/src/assets/images/banners/Emerging_Tech_Banner.png";
import PageLayout from "@/src/layouts/PageLayout.astro";
import base_url from "@/src/lib/base_url";
import "@/src/styles/ai-section.css";
---

<PageLayout title="Overview" bannerImage={banner}>
  <Fragment slot="banner">Artificial Intelligence (AI)</Fragment>
  <main>
    <h2>Artificial Intelligence Overview</h2>
    <div class="row mb-4 g-4">
      <!-- Card 1: How Does AI Work -->
      <div class="col-md-6 col-lg-3">
        <a href={base_url("/research-areas/artificial-intelligence/overview/how-ai-works")} class="text-decoration-none">
          <div class="card p-4 rounded-4 h-100 shadow-sm data-card card-hoverable card-blue">
            <h3 class="text-uppercase">How Does AI Work</h3>
            <p class="mb-0">AI operates as a continuous sense-think-act cycle that extracts actionable insights from massive datasets such as predicting pavement failures or optimizing signal timing serving as a force multiplier for public sector agencies managing complex transportation challenges.</p>
          </div>
        </a>
      </div>

      <!-- Card 2: Where Can AI Advance Transportation -->
      <div class="col-md-6 col-lg-3">
        <a href={base_url("/research-areas/artificial-intelligence/overview/where-ai-advances-transportation")} class="text-decoration-none">
          <div class="card p-4 rounded-4 h-100 shadow-sm data-card card-hoverable card-blue">
            <h3 class="text-uppercase">Where Can AI Advance Transportation</h3>
            <p class="mb-0">AI serves as an intelligence layer for surface transportation, enabling agencies to shift from reactive, retrospective analysis to proactive, predictive management powering real-time adaptive operations, strategic asset management, and data-driven planning that maximizes safety, efficiency, and the value of every dollar invested.</p>
          </div>
        </a>
      </div>

      <!-- Card 3: What Are AI Transportation Use Cases -->
      <div class="col-md-6 col-lg-3">
        <a href={base_url("/research-areas/artificial-intelligence/overview/ai-use-cases")} class="text-decoration-none">
          <div class=" card p-4 rounded-4 h-100 shadow-sm data-card card-hoverable card-blue">
            <h3 class="text-uppercase">What Are AI Transportation Use Cases</h3>
            <p class="mb-0">AI serves as a strategic catalyst for multimodal transportation by fusing diverse data streams to enable real-time predictions, optimized decision-making, and institutional innovation shifting agencies from reactive troubleshooting to anticipatory operations across ITS JPO-categorized program and service areas.</p>
          </div>
        </a>
      </div>

      <!-- Card 4: What Is The JPO AI Implementation Approach -->
      <div class="col-md-6 col-lg-3">
        <a href={base_url("/research-areas/artificial-intelligence/overview/jpo-implementation-approach")} class="text-decoration-none">
          <div class=" card p-4 rounded-4 h-100 shadow-sm data-card card-hoverable card-blue">
            <h3 class="text-uppercase">What Is The JPO AI Implementation Approach</h3>
            <p class="mb-0">The ITS JPO AI Program leads a collaborative, multimodal effort to integrate AI into transportation through research, real-world testing, deployment demonstrations, repeatable frameworks, and knowledge sharing.</p>
          </div>
        </a>
      </div>
    </div>
  </main>
</PageLayout>
