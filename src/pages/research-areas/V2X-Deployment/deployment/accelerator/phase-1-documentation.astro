---
import PageLayout from "@/src/layouts/PageLayout.astro";
import banner from "@/src/assets/images/banners/V2X_Banner.png";

const keywords = ["V2X Accelerator", "Phase 1", "Documentation"];
const description = "Documentation for Phase 1: Finalize, Design, Build, and Test.";
---

<PageLayout title="Phase 1 Documentation — V2X Accelerator" bannerImage={banner} keywords={keywords} description={description}>
  <Fragment slot="banner">Vehicle-to-Everything (V2X)</Fragment>
  <main>
    <section class="mt-0 py-2">
      <h3 class="my-4">Documentation for Phase 1: Finalize, Design, Build, and Test</h3>
      <div class="table-responsive">
        <table class="table table-bordered table-striped">
          <thead class="table-light">
            <tr>
              <th scope="col" style="width: 35%">Task Area / Document</th>
              <th scope="col" style="width: 22%">Maricopa County DOT</th>
              <th scope="col" style="width: 22%">Texas A&amp;M Transportation Institute</th>
              <th scope="col" style="width: 22%">Utah DOT</th>
            </tr>
          </thead>
          <tbody>
            <tr class="section-header" data-section="planning" data-collapsed="true">
              <td colspan="4" class="bg-secondary fw-bold section-header-td">
                <span class="section-label">System Planning and Design</span>
                <button class="toggle-btn" style="background: none; border: none; cursor: pointer; font-weight: bold; color: #fff; font-size: 1rem; padding: 0;">▶</button>
              </td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Systems Engineering Management Plan (SEMP)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><a href="https://rosap.ntl.bts.gov/view/dot/83522" target="_blank" rel="noopener noreferrer">FHWA-JPO-24-150</a></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Concept of Operations (ConOps)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Systems Requirements Document (SyRS)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>System Architecture Document (SAD)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>System Design Document (SDD)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Data Plan</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Comprehensive Installation Plan</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Comprehensive Maintenance and Operations Plan</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="planning" data-hidden="true">
              <td>Performance Measurement and Evaluation Plan</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
     
            <tr class="section-header" data-section="test" data-collapsed="true">
              <td colspan="4" class="bg-secondary fw-bold section-header-td">
                <span class="section-label">System Test and Operational Readiness Demonstration</span>
                <button class="toggle-btn" style="background: none; border: none; cursor: pointer; font-weight: bold; color: #fff; font-size: 1rem; padding: 0;">▶</button>
              </td>
            </tr>
            <tr class="content-row" data-section="test" data-hidden="true">
              <td>Operational Readiness Concept Briefing</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="test" data-hidden="true">
              <td>Operational Readiness Plan (ORP)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="test" data-hidden="true">
              <td>System Test Results Summary</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="test" data-hidden="true">
              <td>Operational Readiness Demonstration Report</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="section-header" data-section="outreach" data-collapsed="true">
              <td colspan="4" class="bg-secondary fw-bold section-header-td">
                <span class="section-label">Stakeholder Outreach and Communications</span>
                <button class="toggle-btn" style="background: none; border: none; cursor: pointer; font-weight: bold; color: #fff; font-size: 1rem; padding: 0;">▶</button>
              </td>
            </tr>
            <tr class="content-row" data-section="outreach" data-hidden="true">
              <td>Outreach Plan</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
            <tr class="content-row" data-section="outreach" data-hidden="true">
              <td>Webinar 1 (Topic TBD)</td>
              <td><a href="https://itsa.org/event/v2x-accelerator-deployment-concept-series-webinar-2-maricopa-county-dot/" target="_blank" rel="noopener noreferrer">October 7, 2025</a></td>
              <td><a href="https://itsa.org/event/v2x-accelerator-deployment-concept-series-webinar-3-texas-am-transportation-institute/" target="_blank" rel="noopener noreferrer">October 15, 2025</a></td>
              <td><a href="https://itsa.org/event/v2x-accelerator-deployment-concept-series-webinar-1-utah-dot/" target="_blank" rel="noopener noreferrer">October 2, 2025</a></td>
            </tr>
            <tr class="content-row" data-section="outreach" data-hidden="true">
              <td>Webinar 2 (Topic TBD)</td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
              <td><em>Under development</em></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

   <script>
  document.querySelectorAll('.section-header').forEach((header: Element) => {
    const sectionName = header.getAttribute('data-section');
    const toggleBtn = header.querySelector('.toggle-btn') as HTMLElement | null;
    
    if (!sectionName || !toggleBtn) return;
    
    header.addEventListener('click', () => {
      const isCollapsed = header.getAttribute('data-collapsed') === 'true';
      const contentRows = document.querySelectorAll(`.content-row[data-section="${sectionName}"]`);
      
      if (isCollapsed) {
        // Collapse other sections first (accordion behavior)
        document.querySelectorAll('.section-header').forEach((otherHeader: Element) => {
          if (otherHeader !== header) {
            const otherSection = otherHeader.getAttribute('data-section');
            const otherToggleBtn = otherHeader.querySelector('.toggle-btn') as HTMLElement | null;
            
            if (!otherSection || !otherToggleBtn) return;
            
            const otherRows = document.querySelectorAll(`.content-row[data-section="${otherSection}"]`);
            otherHeader.setAttribute('data-collapsed', 'true');
            otherToggleBtn.textContent = '▶';
            otherRows.forEach((row: Element) => row.setAttribute('data-hidden', 'true'));
          }
        });
        // Expand current section
        header.removeAttribute('data-collapsed');
        toggleBtn.textContent = '▼';
        contentRows.forEach((row: Element) => row.setAttribute('data-hidden', 'false'));
      } else {
        // Collapse current section
        header.setAttribute('data-collapsed', 'true');
        toggleBtn.textContent = '▶';
        contentRows.forEach((row: Element) => row.setAttribute('data-hidden', 'true'));
      }
    });
  });
</script>
  </main>
</PageLayout>

<style>
    .section-header {
    cursor: pointer;
  }

  .section-header td {
    background-color: #003d7a !important;
    color: #ffffff !important;
    padding: 0.75rem 1rem !important;
  }

  .section-header-td {
    position: relative !important;
    display: table-cell !important;
    width: 100% !important;
    vertical-align: middle !important;
        text-align: start;
  }

  .section-label {
    text-align: left;
    color: #ffffff;
    font-weight: bold;
    display: inline-block;
    margin-right: 1rem;
  }

  .section-header:hover td {
    background-color: #002d5a !important;
  }

  .toggle-btn {
    transition: transform 0.3s ease;
    display: inline-block;
    color: #ffffff !important;
    float: right;
    margin-right: 0.5rem;
  }

  .section-header[data-collapsed="false"] .toggle-btn {
    transform: rotate(90deg);
    transition: transform 0.3s ease;
  }

  .content-row[data-hidden="true"] {
    display: none;
    opacity: 0;
    animation: slideUp 0.3s ease-out forwards;
  }

  .content-row[data-hidden="false"] {
    display: table-row;
    animation: slideDown 0.3s ease-out forwards;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }

  </style>
